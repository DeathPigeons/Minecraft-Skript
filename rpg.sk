on right click with orange dye:
	hasClass(event-player, "nethermancer") is true:
		event-player is not flying:
			send "&4You must be flying to dive!" to event-player
			stop

		set {_loc} to event-player's targeted block
		set {_loc} to location 1 meter above {_loc}
		set pitch of {_loc} to pitch of event-player
		set yaw of {_loc} to yaw of event-player
	

		set {_canTp} to true
		if block at {_loc} is solid:
			set {_canTp} to false
		if block 1 meter above {_loc} is solid:
			set {_canTp} to false
		if y coordinate of {_loc} is greater than y coordinate of event-player:
			set {_canTp} to false
		if {_canTp} is false:
			send "&4Cannot dive there!" to event-player
			stop

		subMana(event-player, 250) is false:
			send "&4Not enough mana to dive!" to event-player
			stop
		regenHeat(event-player, -50)
		
		send "&dYou dive to your target location!" to event-player
		teleport event-player to {_loc}
		create a fake explosion at {_loc}
		loop all entities in radius 7.5 around {_loc}:
			isMonster(loop-entity) is true
			damage loop-entity by 10
			set {_vec} to vector between {_loc} and loop-entity
			set y component of {_vec} to 0
			set {_vec} to normalized {_vec}
			push loop-entity {_vec} with force 0.8
			push loop-entity upwards with force 1.2
			applyEffect(loop-entity, "firestorm", 10 seconds)
			

