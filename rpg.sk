# Warlock

# Monk
function canUseMonkAbilities(player: player) :: boolean:
	if isWearingLightOrLess({_player}) is true:
		return true
	return false

on right click with firework star:
	if hasClass(player, "monk") is true:
		if canUseMonkAbilities(player) is false:
			send "&4You cannot cast the smoke grenade spell!" to player
			stop
	else if hasClass(player, "rogue") is true:
		if canUseRogueAbilities(player) is false:
			send "&4You cannot cast the smoke grenade spell!" to player
			stop
	else:
		send "&4You cannot cast the smoke grenade spell!" to player

	if subEnergy(player, 5) is false:
		send "&4You cannot cast the smoke grenade spell!" to player
		stop
	else:
		send "&4You cast the smoke grenade spell!" to player
		applyEffect(player, "invisible", 10 seconds)
		loop entities in radius 10 around player:
			loop-entity is not player
			apply blindness 2 to the loop-entity for 5 seconds replacing the existing effect
