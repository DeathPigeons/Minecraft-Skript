# General

Options:
	prefix: &c[&eRPG Skript&c]&r
	consolePrefix: &6[&8Console&6]&r
	
	debugPrefix: &e[&bDEBUG&e]&r
	debug: true

	drawRadius: 20

on script load:
	scriptBroadcast("Loading script...")
	scriptDebugBroadcast("Debug Output Enabled")
	
	scriptConsoleMessage("Test console message")
	scriptDebugConsoleMessage("Test debug to console")

on script unload:
	broadcast "{@prefix} &3Unloading script..."
	
	delete {-rpgSkript::fireballs::*}
	delete {-rpgSkript::cryoballs::*}
	delete {-rpgSkript::cache::*}

	loop {-rpgSkript::minions::*}:
		killMinion(loop-index)

	delete {-rpgSkript::minions::*}
	delete {-rpgSkript::effects::*}
	delete {-rpgSkript::worldeffects::*}

on join:
	wait 3 seconds
	send "&c-------- &eMinecraft RPG &c--------" to player
	send "&l&eNew&r&e:" to player

	# Example: send "&3 - <stuff>" to player
	
	send "&3 - New Class: Paladin. Evil falters in their presence!" to player
	send "&3 - New Class: Necromancer. Command the undead to do your bidding" to player
	send "&3 - New Class: Endwarden. Tap into the power of the void to massacre your enemies!" to player
	send "&3 - New Class: Barbarian. Use a new type of energy 'Energy' in order to tank and obliterate your enemies!" to player
	send "&3 - New Class: Druid. Protect the Natural Order with your skills and a trusty companion!" to player
	send "&3 - New Class: Cleric. Channel divine powers to smite your foes!" to player
	send "&3 - New Class: Artificer. Manipulate magic and technology!" to player
	
	send "&3 - Items can now be imbued to grant classes while you are wearing/holding them" to player
	send "&3 - Warrior no longer gets slowness when they take damage" to player
	
	#send "&3" to player

	send "&c-------- &eMinecraft RPG &c--------" to player
	

on chat:
	set the message to "&6[&8LVL %getLevel(player)%&6]&r %message%"
	hasClass(player, "rogue") is true:
		set the message to "&7[&2Rogue&7]&r %message%"
	hasClass(player, "warrior") is true:
		set the message to "&e[&cWarrior&e]&r %message%"
	hasClass(player, "wizard") is true:
		set the message to "&8[&3Wizard&8]&r %message%"
	hasClass(player, "paladin") is true:
		set the message to "&6[&9Paladin&6]&r %message%"
	hasClass(player, "cleric") is true:
		set the message to "&3[&eCleric&3]&r %message%"
	hasClass(player, "sorceror") is true:
		set the message to "&e[&cSorceror&e]&r %message%"
	hasClass(player, "necromancer") is true:
		set the message to "&c[&7Necromancer&c]&r %message%"
	hasClass(player, "barbarian") is true:
		set the message to "&c[&4Barbarian&c]&r %message%"
	hasClass(player, "endwarden") is true:
		set the message to "&0[&9Endwarden&0]&r %message%"
	hasClass(player, "druid") is true:
		set the message to "&6[&aDruid&6]&r %message%"
	hasClass(player, "artificer") is true:
		set the message to "&7[&bArtificer&7]&r %message%"
	hasClass(player, "herobrine") is true:
		set the message to "&0[&4Herobrine&0]&r %message%"
	hasClass(player, "monk") is true:
		set the message to "&e[&2Monk&e]&r %message%"
	hasClass(player, "Nethermancer") is true:
		set the message to "&0[&4Nethermancer&0]&r %message%"

function rpgLog(message: text):
	log "%{_message}%" to "rpg/main.log"

function scriptBroadcast(message: text):
	broadcast "{@prefix} &3%{_message}%"

function scriptConsoleMessage(message: text):
	send "{@consolePrefix} {@prefix} &3%{_message}%" to console

function shouldPrintDebugType(type: string) :: boolean:
	if {-rpgSkript::debug::%{_type}%} is not set:
		set {-rpgSkript::debug::%{_type}%} to false
	return {-rpgSkript::debug::%{_type}%}

function scriptDebugBroadcast(message: text):
	scriptDebugBroadcastType("main", {_message})

function scriptDebugBroadcastType(type: string, message: text):
	{@debug} is true:
		shouldPrintDebugType({_type}) is true:
			broadcast "{@debugPrefix} %{_type}% {@prefix} &7%{_message}%"

function scriptDebugConsoleMessage(message: text):
	scriptDebugConsoleMessageType("main", {_message})

function scriptDebugConsoleMessageType(type: string, message: text):
	{@debug} is true:
		shouldPrintDebugType({_type}) is true:
			send "{@consolePrefix} %{_type}% {@debugPrefix} {@prefix} &7%{_message}%" to console

command /rpgdebug <string> <boolean>:
	trigger:
		command executor has permission "rpg.control"
		set {-rpgSkript::debug::%arg 1%} to arg 2
		send "&3Debug logging changed" to command executor

command /rpgdebugged:
	trigger:
		command executor has permission "rpg.control"
		loop {-rpgSkript::debug::*}:
			send "&3%loop-index% -> %loop-value%" to command executor

command /rpgdebugreset:
	trigger:
		command executor has permission "rpg.control"
		delete {-rpgSkript::debug::*}
		send "&cEnabled debug types reset" to command executor

command /killMobs:
	trigger:
		command executor has permission "rpg.control"
		loop all entities:
			isMonster(loop-entity)
			loop-entity is not a player
			kill loop-entity
			wait 1.5 ticks

function giveItem(player: player, item: item) :: boolean:
	{_player} doesn't have space for {_item}:
		send "&cYou don't have space for %{_item}%" to {_player}
		scriptConsoleMessage("Failed to give %{_item}% to %{_player}%")
		return false
	give {_item} to {_player}
	send "&aYou receive %{_item}%" to {_player}
	scriptConsoleMessage("Gave %{_item}% to %{_player}%")
	return true

function hasClass(player: player, class: text) :: boolean:
	if {_player} has permission "rpg.%{_class}%":
		return true
#	if hasImbue({_player}, "%{_class}% class") is true:
#		return true
	return false

function isMonster(entity: entity) :: boolean:
	{_entity} is a player:
		hasClass({_entity}, "herobrine") is true:
			return true
	isMinion({_entity}) is true:
		return false
	{_entity} is a monster:
		return true
	{_entity} is a phantom:
		return true
	{_entity} is a shulker:
		return true
	{_entity} is a hoglin:
		return true
	{_entity} is a magma slime:
		return true
	return false

function isFriendlyMob(entity: entity) :: boolean:
	{_entity} is a player:
		return false
	isMinion({_entity}) is true:
		return false
	{_entity} is a pig:
		return true
	{_entity} is a cow:
		return true
	{_entity} is a sheep:
		return true
	{_entity} is a chicken:
		return true
	{_entity} is a bee:
		return true
	{_entity} is a golem:
		return true
	{_entity} is a villager:
		return true
	{_entity} is a wolf:
		return true
	{_entity} is a cat:
		return true
	{_entity} is a horse:
		return true
	return false

function setMaxHealth(player: player):
	set {_newMax} to 10
	if hasClass({_player}, "herobrine") is true:
		set {_newMax} to 40
	else if hasClass({_player}, "warrior") is true:
		set {_newMax} to 20
		if hasResearch({_player}, "durable") is true:
			set {_newMax} to {_newMax} * 1.25
	else if hasClass({_player}, "barbarian") is true:
		set {_newMax} to 15
	else if hasClass({_player}, "druid") is true:
		set {_newMax} to 15
	else if hasClass({_player}, "nethermancer") is true:
		set {_newMax} to 12
	else if hasClass({_player}, "wizard") is true:
		set {_newMax} to 8
	else if hasClass({_player}, "sorceror") is true:
		set {_newMax} to 8
	else if hasClass({_player}, "endwarden") is true:
		set {_newMax} to 8
	else:
		set {_newMax} to 10

	hasClass({_player}, "druid") is true:
		sun light level at {_player} is greater than 5:
			set {_newMax} to {_newMax} * 1.20
	
		if {rpgSkript::%{_player}%::batshape} is true:
			set {_newMax} to 0.25 * {_newMax} 
		else if {rpgSkript::%{_player}%::wolfshape} is true:
			set {_newMax} to 1.0 * {_newMax}
		else if {rpgSkript::%{_player}%::horseshape} is true:
			set {_newMax} to 1.3 * {_newMax}
		else if {rpgSkript::%{_player}%::spidershape} is true:
			set {_newMax} to 0.9 * {_newMax} 
		else if {rpgSkript::%{_player}%::bearshape} is true:
			set {_newMax} to 2.5 * {_newMax}

	hasClass({_player}, "necromancer") is true:
		if {rpgSkript::%{_player}%::ritualstr} is true:
			set {_newMax} to 1.5 * {_newMax}

	if hasImbue({_player}, "Health Boost") is true:
		set {_newMax} to ({_newMax} + {_newMax} * 0.15 * countImbue({_player}, "Health Boost"))

	if hasImbue({_player}, "golem") is true:
		set {_newMax} to {_newMax} * (1 + (0.2 * countImbue({_player}, "golem")))

	if hasImbue({_player}, "guardian") is true:
		set {_newMax} to {_newMax} * 1.5

	hasEffect({_player}, "inspired") is true:
		set {_newMax} to {_newMax} * 1.1

	hasImbue({_player}, "photosynthesis") is true:
		sun light level at {_player} is greater than 13:
			time in world of {_player} is not between 19:00 and 5:00:
				set {_newMax} to {_newMax} * ( 1 + 0.1 * countImbue({_player}, "photosynthesis") )

	hasEffect({_player}, "disease") is true:
		hasImbue({_player}, "iron will") is false:
			set {_newMax} to {_newMax} * 0.65

	hasEffect({_player}, "soulbond") is true:
		set {_newMax} to {_newMax} * 1.05
	hasEffect({_player}, "meditated") is true:
		set {_newMax} to {_newMax} * 1.25
	hasEffect({_player}, "rage") is true:
		set {_newMax} to {_newMax} * (5 / 3)

	set {_newMax} to {_newMax} * calculateCoreStatBonus({_player}, "health")

	set {_newMax} to ceil({_newMax})
	if {_player}'s maximum health is not {_newMax}:
		set {_player}'s maximum health to {_newMax}
		send "&cYour maximum health has changed to %{_newMax}% hearts" to {_player}

	scriptDebugBroadcastType("health", "%{_player}%'s max health is now %{_newMax}%")

function canFly(player: player):: boolean:
	if {rpgSkript::%{_player}%::batshape} is true:
		return true
	if {_player}'s gamemode is not survival:
		return true
	if hasClass({_player}, "herobrine") is true:
		return true
	if hasClass({_player}, "nethermancer") is true:
		if {rpgSkript::heat::%{_player}%} is greater than 499:
			return true
	return false

function getItemCostForImbue(imbue: text, item: item):: items:

	# Artificer

	if {_imbue} is "vampiric":
		return (8 copper ingot and 16 redstone)
	else if {_imbue} is "hallowed":
		return (32 quartz and 3 diamond)
	else if {_imbue} is "shocking":
		return (32 lapis lazuli and 16 copper ingot)
	else if {_imbue} is "bleeding":
		return (8 iron ingot and 12 copper ingot)
	else if {_imbue} is "mana leak":
		return (24 lapis lazuli and 24 quartz and 4 diamond)
	else if {_imbue} is "golem":
		return (64 cobblestone and 12 iron ingot)
	else if {_imbue} is "flame shield":
		return (8 flint and 16 gold ingot)
	else if {_imbue} is "mana shield":
		return (24 lapis lazuli and 24 redstone and 4 diamond)
	else if {_imbue} is "excavation":
		return (8 gold ingot and 12 copper ingot)
	else if {_imbue} is "repulsor":
		return (32 quartz and 32 copper ingot)
	else if {_imbue} is "firststrike":
		return (4 diamond and 32 quartz)
	else if {_imbue} is "detonate":
		return (48 redstone and 16 copper ingot and 16 gunpowder)
	else if {_imbue} is "Frost Shield":
		return (4 diamond and 32 copper ingot)
	else if {_imbue} is "Iron Will":
		return (48 iron ingot and 24 copper ingot and 2 netherite ingot)
	else if {_imbue} is "speed":
		return (28 quartz and 24 copper ingot and 12 gold ingot)

	else if {_imbue} is "reinforced":
		if at least one of:
			{_item} is a diamond pickaxe
			{_item} is a diamond shovel
			{_item} is a diamond hoe
			{_item} is a diamond sword
			{_item} is a diamond axe
			{_item} is a diamond chestplate
			{_item} is a diamond leggings
			{_item} is a diamond boots
			{_item} is a diamond helmet
		then:
			return (12 leather and 12 diamond)		
		if at least one of:
			{_item} is a iron pickaxe
			{_item} is a iron shovel
			{_item} is a iron hoe
			{_item} is a iron sword
			{_item} is a iron axe
			{_item} is a iron chestplate
			{_item} is a iron leggings
			{_item} is a iron boots
			{_item} is a iron helmet
			{_item} is a shield
			{_item} is a trident
		then:
			return (12 leather and 12 iron ingot)
		if at least one of:
			{_item} is a wood pickaxe
			{_item} is a wood shovel
			{_item} is a wood hoe
			{_item} is a wood sword
			{_item} is a wood axe
			{_item} is a bow
			{_item} is a crossbow
		then:
			return (12 leather)
		if at least one of:
			{_item} is a stone pickaxe
			{_item} is a stone shovel
			{_item} is a stone hoe
			{_item} is a stone sword
			{_item} is a stone axe
			{_item} is a chain chestplate
			{_item} is a chain leggings
			{_item} is a chain boots
			{_item} is a chain helmet
		then:
			return (12 leather and 12 cobblestone)
		if at least one of:
			{_item} is a netherite pickaxe
			{_item} is a netherite shovel
			{_item} is a netherite hoe
			{_item} is a netherite sword
			{_item} is a netherite axe
			{_item} is a netherite chestplate
			{_item} is a netherite leggings
			{_item} is a netherite boots
			{_item} is a netherite helmet
		then:
			return (12 leather and 12 netherite ingot)
		if at least one of:
			{_item} is a gold pickaxe
			{_item} is a gold shovel
			{_item} is a gold hoe
			{_item} is a gold sword
			{_item} is a gold axe
			{_item} is a gold chestplate
			{_item} is a gold leggings
			{_item} is a gold boots
			{_item} is a gold helmet
		then:
			return (12 leather and 12 gold ingot)




	
			
	# Artificer Non-Weapons/Tools

	else if {_imbue} is "lesser mine":
		return (1 tnt and 2 redstone)
	else if {_imbue} is "greater mine":
		return (1 tnt and 2 redstone)
	else if {_imbue} is "poison mine":
		return (1 spider eye and 2 redstone and 1 nether wart)
	else if {_imbue} is "auto mine":
		return (4 redstone and 2 copper ingot)
	# Wizard

	else if {_imbue} is "health":
		return (96 nether wart and 64 glowstone dust)
	else if {_imbue} is "mana":
		return (2 diamond and 6 gold ingot)
	else if {_imbue} is "siphon":
		return (2 diamond and 48 quartz)
	else if {_imbue} is "Enlighten":
		return (64 lapis lazuli and 64 quartz and 4 diamond)

	# Druid

	else if {_imbue} is "Photosynthesis":
		return (24 lapis lazuli and 24 quartz and 4 diamond)

command /ingredients <text>:
	executable by: players
	trigger:
		set {_item} to player's held item
		set {_cost::*} to getItemCostForImbue(arg 1, {_item})
		if {_cost::*} is set:
			send "&e%arg 1 in lower case% costs: %{_cost::*}%" to the player
		else:
			send "&cNot a valid imbuement" to the player

function lastLoreLine(item: item) :: number:
	set {_x} to 1
	loop lore of {_item}:
		set {_x} to {_x} + 1
	return {_x}

command /addLore <text>:
	executable by: players
	trigger:
		player has permission "rpg.control":
			addImbue(player's held item, "arg 1")

function hasAnyImbue(item: item) :: boolean:
	if lastLoreLine({_item}) is 1:
		return false
	return true

function addImbue(item: item, imbue: text) :: item:
	hasLore({_item}, {_imbue}) is true:
		return {_item}
	set line lastLoreLine({_item}) of ({_item})'s lore to {_imbue}
	scriptDebugBroadcastType("imbue", "%{_item}% imbue %{_imbue}%")
	return {_item}

function countImbue(player: player, text: text) :: number:
	set {_c} to 0
	if hasLore({_player}'s helmet, {_text}) is true:
		set {_c} to {_c} + 1
	if hasLore({_player}'s chestplate, {_text}) is true:
		set {_c} to {_c} + 1
	if hasLore({_player}'s leggings, {_text}) is true:
		set {_c} to {_c} + 1
	if hasLore({_player}'s boots, {_text}) is true:
		set {_c} to {_c} + 1
	if {_text} is not "reinforced":
		if hasLore({_player}'s held item, {_text}) is true:
			set {_c} to {_c} + 1
		if hasLore({_player}'s off hand item, {_text}) is true:
			set {_c} to {_c} + 1
	return {_c}

function hasImbue(player: player, text: text) :: boolean:
	if hasLore({_player}'s helmet, {_text}) is true:
		return true
	if hasLore({_player}'s chestplate, {_text}) is true:
		return true
	if hasLore({_player}'s leggings, {_text}) is true:
		return true
	if hasLore({_player}'s boots, {_text}) is true:
		return true
	if hasLore({_player}'s held item, {_text}) is true:
		return true
	if hasLore({_player}'s off hand item, {_text}) is true:
		return true
	return false

function hasLore(item: item, text: text) :: boolean:
	loop lore of {_item}:
		if loop-value contains {_text}:
			return true
	return false

function isWearingLightOrLess(player: player) :: boolean:
	if isWearingNothing({_player}) is true:
		return true
	hasLore(helmet of {_player}, "light") is false:
		helmet of {_player} is not (leather helmet or air or chainmail helmet):
			hasLore(helmet of {_player}, "weightless") is false:
				return false
	hasLore(chestplate of {_player}, "light") is false:
		chestplate of {_player} is not (leather chestplate or air or chainmail chestplate):
			hasLore(chestplate of {_player}, "weightless") is false:
				return false
	hasLore(leggings of {_player}, "light") is false:
		leggings of {_player} is not (leather leggings or air or chainmail leggings):
			hasLore(leggings of {_player}, "weightless") is false:
				return false
	hasLore(boots of {_player}, "light") is false:
		boots of {_player} is not (leather boots or air or chainmail boots):
			hasLore(boots of {_player}, "weightless") is false:
				return false
	if checkOffHandType({_player}) is not ("weightless" or "light"):
		return false
	return true

function isWearingNothing(player: player) :: boolean:
	hasLore(helmet of {_player}, "weightless") is false:
		helmet of {_player} is not (air):
			return false
	hasLore(chestplate of {_player}, "weightless") is false:
		chestplate of {_player} is not (air):
			return false
	hasLore(leggings of {_player}, "weightless") is false:
		leggings of {_player} is not (air):
			return false
	hasLore(boots of {_player}, "weightless") is false:
		boots of {_player} is not (air):
			return false
	if checkOffHandType({_player}) is not "weightless":
		return false
	return true

function isWearingMediumOrLess(player: player) :: boolean:
	if isWearingLightOrLess({_player}) is true:
		return true
	hasLore(helmet of {_player}, "light") is false:
		helmet of {_player} is (diamond helmet or netherite helmet):
			hasLore(helmet of {_player}, "weightless") is false:
				return false
	hasLore(chestplate of {_player}, "light") is false:
		chestplate of {_player} is (diamond chestplate or netherite chestplate):
			hasLore(chestplate of {_player}, "weightless") is false:
				return false
	hasLore(leggings of {_player}, "light") is false:
		leggings of {_player} is (diamond leggings or netherite leggings):
			hasLore(leggings of {_player}, "weightless") is false:
				return false
	hasLore(boots of {_player}, "light") is false:
		boots of {_player} is (diamond boots or netherite boots):
			hasLore(boots of {_player}, "weightless") is false:
				return false
	if checkOffHandType({_player}) is not ("weightless" or "light" or "medium"):
		return false
	return true

function isWearingHeavyOrLess(player: player) :: boolean:
	return true

function checkOffHandType(player: player) :: string:
	hasLore(off hand item of {_player}, "weightless") is true:
		return "weightless"
	hasLore(off hand item of {_player}, "light") is true:
		return "light"
	if at least one of:
		off hand item of {_player} is netherite helmet
		off hand item of {_player} is netherite chestplate
		off hand item of {_player} is netherite leggings
		off hand item of {_player} is netherite boots
		off hand item of {_player} is diamond helmet
		off hand item of {_player} is diamond chestplate
		off hand item of {_player} is diamond leggings
		off hand item of {_player} is diamond boots
	then:
		return "heavy"
	if at least one of:
		off hand item of {_player} is gold helmet
		off hand item of {_player} is gold chestplate
		off hand item of {_player} is gold leggings
		off hand item of {_player} is gold boots
		off hand item of {_player} is iron helmet
		off hand item of {_player} is iron chestplate
		off hand item of {_player} is iron leggings
		off hand item of {_player} is iron boots
		off hand item of {_player} is shield
	then:
		return "medium"
	if at least one of:
		off hand item of {_player} is leather helmet
		off hand item of {_player} is leather chestplate
		off hand item of {_player} is leather leggings
		off hand item of {_player} is leather boots
		off hand item of {_player} is chainmail helmet
		off hand item of {_player} is chainmail chestplate
		off hand item of {_player} is chainmail leggings
		off hand item of {_player} is chainmail boots
		off hand item of {_player} is a banner
	then:
		return "light"
	return "weightless"
	

function rollDie(sides: number) :: number:
	set {_value} to a random integer between 1 and {_sides}
	scriptDebugBroadcastType("dice", "rollDie(%{_sides}%) = %{_value}%")
	return {_value}

function rollDice(dice: number, sides: number) :: number:
	set {_total} to 0
	loop {_dice} times:
		add rollDie({_sides}) to {_total}
	scriptDebugBroadcastType("dice", "rollDice(%{_dice}%, %{_sides}%) = %{_total}%")
	return {_total}

command /dice <number> <number>:
	trigger:
		set {_value} to rollDice(arg 1, arg 2)
		send "&9 %arg 1%d%arg 2% -> %{_value}%" to command executor

function addResearch(player: player, name: string, level: number=1):
	set {rpgSkript::%{_player}%::research::%{_name}%} to {_level}
	send "&eYou have earned research ""%{_name}%"" Level %{_level}%" to {_player}

function deleteResearch(player: player, name: string):
	delete {rpgSkript::%{_player}%::research::%{_name}%}
	send "&cYou have lost research ""%{_name}%""" to {_player}

function hasResearch(player: player, name: string) :: boolean:
	if {rpgSkript::%{_player}%::research::%{_name}%} is set:
		return true
	return false

function getResearchLevel(player: player, name: string) :: number:
	if {rpgSkript::%{_player}%::research::%{_name}%} is not set:
		return 0
	return {rpgSkript::%{_player}%::research::%{_name}%}

function explodeRadius(block: block, range: number):
	loop all blocks in radius {_range} around {_block}:
		loop-block is not bedrock:
			break loop-block naturally using diamond pickaxe

local function drawLine(loc1: location, loc2: location):
	set {_v} to vector from {_loc1} to {_loc2}
	set vector length of {_v} to 0.25
	loop floor((distance between {_loc1} and {_loc2}) / 0.25) times:
		draw 1 flame at {_loc1} with extra 0
		set {_loc1} to {_loc1} ~ {_v}

function playSoundToPlayers(loc: location, sound: string, range: number, pitch: number=1):
	loop players in radius {_range} of {_loc}:
		play sound "%{_sound}%" with pitch {_pitch} for loop-player

command /haslore <text>:
	executable by: players
	trigger:
		send "hasImbue: %hasImbue(command executor, arg 1)%"

command /armorclass:
	executable by: players
	trigger:
		send "Light or less: %isWearingLightOrLess(command executor)%"
		send "Medium or less: %isWearingMediumOrLess(command executor)%"
		send "Heavy or less: %isWearingHeavyOrLess(command executor)%"

function arcaneTide():
	{rpgSkript::arcaneTide} is not set:
		set {_x} to a random number between 1 and 1000
		#broadcast {_x}
		{_x} < 7:
			set {rpgSkript::arcaneTide} to now
			arcaneSense("You feel the surrounding energy of Magic become more intense!")
	else:
		if difference between now and {rpgSkript::arcaneTide} is greater than 2 minutes:
			set {_x} to a random number between 1 and 1000
			#broadcast {_x}
			{_x} < 20:
				delete {rpgSkript::arcaneTide}
				arcaneSense("The energy in the air settles...")

function countEntities(mobs: entities) :: number:
	set {_x} to 0
	loop {_mobs::*}:
		set {_x} to {_x} + 1
	return {_x}

on heal:
	entity is not alive:
		cancel the event

function fullHeal(entity: entity):
	heal({_entity}, max health of {_entity})

function heal(entity: entity, amount: number) :: boolean:
	if {_entity} is not alive:
		return false
	if hasEffect({_entity}, "radiated") is true:
		hasImbue({_entity}, "radiation") is false
		return false
	if hasEffect({_entity}, "antiheal") is true:
		return false
	{_entity} is a player:
		hasClass({_entity}, "cleric") is true:
			set {_amount} to {_amount} * 2
	heal {_entity} by {_amount}
	scriptDebugBroadcastType("heal", "%{_entity}% heals for %{_amount}%")
	return true

on join:
	setMaxHealth(the player)
	set the player's health to the player's health

function createWorldEffect(loc: location, name: text, duration: time span, creator: entity={_none}):
	set {_id} to a random UUID
	set {-rpgSkript::worldeffects::%{_id}%} to 0
	set {-rpgSkript::worldeffects::%{_id}%::location} to {_loc}
	set {-rpgSkript::worldeffects::%{_id}%::name} to {_name}
	set {-rpgSkript::worldeffects::%{_id}%::duration} to {_duration}
	set {-rpgSkript::worldeffects::%{_id}%::creator} to {_creator}
	set {-rpgSkript::worldeffects::%{_id}%::started} to now
	scriptDebugBroadcastType("world_effect", "Created world effect %{_name}% at %{_loc}% for %{_duration}%, created by %{_creator}%")

function drawWorldEffect(index: text):
	set {_loc} to {-rpgSkript::worldeffects::%{_index}%::location}
	set {_name} to {-rpgSkript::worldeffects::%{_index}%::name}

	{_name} is "electric_smoke":
		loop blocks in radius 12 around {_loc}:
			chance of 5%:
				show cloud at loop-block
	{_name} is "poison_gas":
		loop blocks in radius 6.99 around {_loc}:
			chance of 5%:
				show green dust at loop-block
				show grey dust at loop-block

	{_name} is "tremors":
		loop blocks in radius 6.99 around {_loc}:
			chance of 5%:
				show brown dust at loop-block
				show green dust at loop-block

		{_name} is "disease":
			loop blocks in radius 6.99 around {_loc}:
				chance of 15%:
					show green dust at loop-block
					show falling spore blossom at loop-block

	{_name} is "blight":
		loop blocks in radius 4.99 around {_loc}:
			chance of 10%:
				show black dust at loop-block
				show grey dust at loop-block
			chance of 5%:
				show purple dust at loop-block

	{_name} is "cobweb":
		loop blocks in radius 9.99 around {_loc}:
			chance of 10%:
				show white dust at loop-block
				show grey dust at loop-block
			chance of 5%:
				show black dust at loop-block

	{_name} is "singularity":
		loop blocks in radius 9.99 around {_loc}:
			chance of 10%:
				show white dust at loop-block
				show black dust at loop-block
			chance of 5%:
				show purple dust at loop-block

	{_name} is "forced teleport":
		loop blocks in radius 2.99 around {_loc}:
			chance of 10%:
				show grey dust at loop-block
				show black dust at loop-block
			chance of 5%:
				show purple dust at loop-block

	{_name} is "black hole":
		loop blocks in radius 9.99 around {_loc}:
			chance of 10%:
				show black dust at loop-block
			chance of 5%:
				show white dust at loop-block

	{_name} is "levitate":
		loop blocks in radius 4.99 around {_loc}:
			chance of 5%:
				show purple dust at loop-block

	{_name} is "holy pillar":
		set {_loctemp} to {_loc}
		loop 5 times:
			loop blocks in radius 4.99 around {_loctemp}:
				loop-block is air
				chance of 5%:
					show white dust at loop-block
				chance of 5%:
					show yellow dust at loop-block
			set {_loctemp} to the location 5 blocks above {_loctemp}

#	{_name} is "worldfire":
#		set {_t1} to unix timestamp of 0 seconds ago
#		set {_t2} to unix timestamp of {-rpgSkript::worldeffects::%{_id}%::started}
#		
#		set {_duration} to {-rpgSkript::worldeffects::%{_id}%::duration}
#		# t3 is the duration converted to a number, seconds
#		set {_t3} to convertTimespanToSeconds({_duration})		
#		set {_fraction} to {_diff} / {_t3}		
#		set {_radius} to 4.99 + ({_fraction} * 10)
#		loop blocks in radius {_radius} around {_loc}:
#			chance of 5%:
#				show mob spawner flames at loop-block
		
			

function handleWorldEffect(index: text):
	set {_loc} to {-rpgSkript::worldeffects::%{_index}%::location}
	set {_name} to {-rpgSkript::worldeffects::%{_index}%::name}
	set {_started} to {-rpgSkript::worldeffects::%{_index}%::started}
	set {_duration} to {-rpgSkript::worldeffects::%{_index}%::duration}
	set {_creator} to {-rpgSkript::worldeffects::%{_index}%::creator}

	set {_diff} to difference between now and {_started}
	{_diff} is greater than {_duration}:
		delete {-rpgSkript::worldeffects::%{_index}%::*}
		delete {-rpgSkript::worldeffects::%{_index}%}
		scriptDebugBroadcastType("world_effect", "Deleted world effect %{_name}% at %{_loc}%")
		stop

	{_name} is "electric_smoke":
		loop entities in radius 13 around {_loc}:
			chance of 60%:
				damage loop-entity by 1

	{_name} is "tremors":
		loop entities in radius 7 around {_loc}:
			chance of 30%:
				if {-evilSkript::%{_creator}%::isBoss} is true:
					if at least one of:
						loop-entity is an evoker
						loop-entity is a ravager
						loop-entity is a pillager
						loop-entity is a vindicator
						loop-entity is a vex
						loop-entity is a witch
					then:
						continue
				damage loop-entity by 3
				isMinion(loop-entity) is true:
					damage loop-entity by 1.5
				set {_vec} to vector between loop-entity and {_loc}
				set y component of {_vec} to 0
				set {_vec} to normalized {_vec}
				push loop-entity {_vec} with force 1.5
				push loop-entity upwards with force 0.75				

	{_name} is "poison_gas":
		loop entities in radius 7 around {_loc}:
			chance of 60%:
				{rpgSkript::%loop-entity%::isBoss} is false
				apply poison 1 to the loop-entity for 10 seconds replacing the existing effect
				if {-evilSkript::%{_creator}%::isBoss} is true:
					loop-entity is not an evoker
					loop-entity is not a ravager
					loop-entity is not a pillager
					loop-entity is not a vindicator
					loop-entity is not a vex
					loop-entity is not a witch
					apply poison 2 to the loop-entity for 10 seconds replacing the existing effect
					apply slowness 2 to the loop-entity for 3 seconds replacing the existing effect
					apply weakness 2 to the loop-entity for 3 seconds replacing the existing effect
					isMinion(loop-entity) is true:
						damage loop-entity by 1.5
				else:
					apply slowness 1 to the loop-entity for 3 seconds replacing the existing effect
					apply weakness 1 to the loop-entity for 3 seconds replacing the existing effect
	{_name} is "disease":
		loop entities in radius 4.99 around {_loc}:
			chance of 30%:
				applyEffect(loop-entity, "disease", 1 minute)
	{_name} is "blight":
		loop entities in radius 7 around {_loc}:
			hasClass(loop-entity, "necromancer") is true:
				exit 1 loop
			isMinion(loop-entity) is true:
				hasClass( getSummoner(uuid of loop-entity) , "necromancer") is true:
					exit 1 loop
			damage loop-entity by 2
			apply blindness 1 to the loop-entity for 3 seconds replacing the existing effect
			{rpgSkript::%loop-entity%::isBoss} is false
			apply weakness 1 to the loop-entity for 3 seconds replacing the existing effect
	{_name} is "cobweb":
		loop entities in radius 10 around {_loc}:
			hasClass(loop-entity, "druid") is true:
				exit 1 loop
			isMinion(loop-entity) is true:
				hasClass( getSummoner(uuid of loop-entity) , "druid") is true:
					exit 1 loop
			isMonster(loop-entity) is true:
				loop-entity is a spider:
					exit 1 loop
			damage loop-entity by 0.5
			if {-evilSkript::%{_creator}%::isBoss} is true:
				damage loop-entity by 1.5
				isMinion(loop-entity) is true:
					damage loop-entity by 1.5
			{rpgSkript::%loop-entity%::isBoss} is false
			apply slowness 2 to the loop-entity for 3 seconds replacing the existing effect
			apply weakness 2 to the loop-entity for 3 seconds replacing the existing effect
	{_name} is "singularity":
		loop entities in radius 10 around {_loc}:
			hasClass(loop-entity, "endwarden") is true:
				applyEffect(loop-entity, "invisible", 5 seconds)
				exit 1 loop
			damage loop-entity by 1
			{rpgSkript::%loop-entity%::isBoss} is false
			apply slowness 2 to the loop-entity for 5 seconds replacing the existing effect
			apply blindness 2 to the loop-entity for 5 seconds replacing the existing effect
			applyEffect(loop-entity, "Void", 10 seconds)
	{_name} is "black hole":
		set {_monsters} to 0
		loop all entities in radius 20 around {_loc}:
			hasClass(loop-entity, "endwarden") is true:
				applyEffect(loop-entity, "invisible", 5 seconds)
				exit 1 loop
			set {_vec} to vector between loop-entity and {_loc}
			set y component of {_vec} to 0
			set {_vec} to normalized {_vec}
			push loop-entity {_vec} with force 1.5
			push loop-entity upwards with force 0.75
			applyEffect(loop-entity, "void", 30 seconds)
			subMana(loop-entity, 30, false)
			damage loop-entity by 1.5
			set {_monsters} to {_monsters} + 1
			wait 3 ticks
			if {_monsters} is greater than 9:
				loop all entities in radius 8 around ({_loc}):
					loop-entity-2 is not a dropped item
					damage loop-entity-2 by 10
					chance of 50%:
						create an explosion with force 3 at {_loc}
					set {_diff} to {_duration} + 1
					wait 5 ticks
	{_name} is "levitate":
		loop all entities in radius 5 around {_loc}:
			hasClass(loop-entity, "endwarden") is true:
				applyEffect(loop-entity, "invisible", 5 seconds)
				exit 1 loop
			applyEffect(loop-entity, "levitate", 10 seconds)

	{_name} is "holy beam":
		loop all entities in radius 15 around {_loc}:
			loop-entity is a monster
			damage loop-entity by 3

	{_name} is "dampen":
		loop all entities in radius 10 around {_loc}:
			if loop-entity is a projectile:
				delete loop-entity
			else:
				if at least one of:
					isFriendlyMob(loop-entity) is true
					loop-entity is a player
				then:
					applyEffect(loop-entity, "shielded", 5 seconds)

#	{_name} is "worldfire":
#		set {_t1} to unix timestamp of 0 seconds ago
#		set {_t2} to unix timestamp of {-rpgSkript::worldeffects::%{_id}%::started}
#		
#		set {_duration} to {-rpgSkript::worldeffects::%{_id}%::duration}
#		# t3 is the duration converted to a number, seconds
#		set {_t3} to convertTimespanToSeconds({_duration})		
#		set {_fraction} to {_diff} / {_t3}		
#		set {_radius} to 4.99 + ({_fraction} * 10)
#		loop entities in radius {_radius} around {_loc}:
#			loop-entity is not a dropped item
#			hasClass(loop-entity, "nethermancer") is false
#			applyEffect(loop-entity, "firestorm", 5 seconds)
#			applyEffect(loop-entity, "antiheal", 5 seconds)
#			damage loop-entity by 3
			
	
				
			
		


every 5 ticks:
	loop {-rpgSkript::worldeffects::*}:
		drawWorldEffect(loop-index)

every 10 ticks:
	loop {-rpgSkript::worldeffects::*}:
		handleWorldEffect(loop-index)

function generateIndex(entity: entity) :: text:
	{_entity} is a player:
		set {_index} to name of {_entity}
	else:
		set {_index} to "entity-%uuid of {_entity}%"
	scriptDebugBroadcastType("generateIndex", "%{_index}%")
	return {_index}

function removeAllEffects(entity: entity):
	set {_index} to generateIndex({_entity})
	loop {-rpgSkript::effects::%{_index}%::*}:
		removeEffect({_entity}, loop-index)

function removeNegativeEffects(entity:entity):
	set {_index} to generateIndex({_entity})
	loop {-rpgSkript::effects::%{_index}%::*}:
		if at least one of:
			loop-index is "shocking"
			loop-index is "bleeding"
			loop-index is "vulnerable"
			loop-index is "infected"
			loop-index is "disease"
			loop-index is "mana leak"
			loop-index is "firestorm"
			loop-index is "phased"
			loop-index is "void"
			loop-index is "levitate"
			loop-index is "radiated"
		then:
			removeEffect({_entity}, loop-index)
function removeEffect(entity: entity, name: string):
	scriptDebugBroadcastType("removeeffect", "Removing Effect %{_name}% from %{_entity}%")
	set {_index} to generateIndex({_entity})
	delete {-rpgSkript::effects::%{_index}%::%{_name}%}
	delete {-rpgSkript::effects::%{_index}%::%{_name}%::*}


function applyEffect(entity: entity, name: string, duration: timespan):
	scriptDebugBroadcastType("applyeffect", "Applying Effect %{_name}% to %{_entity}% for %{_duration}%")
	set {_index} to generateIndex({_entity})
	set {-rpgSkript::effects::%{_index}%::%{_name}%} to 0
	set {-rpgSkript::effects::%{_index}%::%{_name}%::duration} to {_duration}
	set {-rpgSkript::effects::%{_index}%::%{_name}%::applied} to now

function hasEffect(entity: entity, name: string) :: boolean:
	{_entity} is a player:
		hasImbue({_entity}, "%{_name}% effect") is true:
			return true
	set {_index} to generateIndex({_entity})
	{-rpgSkript::effects::%{_index}%::%{_name}%} is not set:
		return false
	set {_diff} to difference between now and {-rpgSkript::effects::%{_index}%::%{_name}%::applied}
	{_diff} is greater than {-rpgSkript::effects::%{_index}%::%{_name}%::duration}:
		return false
	return true

function convertTimespanToSeconds(span: timespan) :: number:
    set {_toRet} to 0
    set {_jump} to 1000

    while {_jump} is greater than or equal to 0.1:
        add {_jump} to {_toRet}
        set {_parse} to "%{_toRet}% seconds" parsed as timespan
        if {_parse} is greater than {_span}:
            subtract {_jump} from {_toRet}
            set {_jump} to {_jump} / 10

    return {_toRet}

function fractionOfEffectRun(entity: entity, name: string) :: number:
    if hasEffect({_entity}, {_name}) is false:
        scriptDebugBroadcastType("fractionOfEffectRun", "Effect Complete/Non Existent")
        return 1
    set {_index} to generateIndex({_entity})
    {-rpgSkript::effects::%{_index}%::%{_name}%} is not set:
        scriptDebugBroadcastType("fractionOfEffectRun", "Effect Complete/Non Existent")
        return 1
        
    if {-rpgSkript::effects::%{_index}%::%{_name}%::duration} is 0:
        return 1
        
    set {_t1} to unix timestamp of 0 seconds ago
    set {_t2} to unix timestamp of {-rpgSkript::effects::%{_index}%::%{_name}%::applied}
    
    set {_duration} to {-rpgSkript::effects::%{_index}%::%{_name}%::duration}
    # t3 is the duration converted to a number, seconds
    set {_t3} to convertTimespanToSeconds({_duration})
    
    scriptDebugBroadcastType("fractionOfEffectRun", "t3 = %{_t3}%")
    set {_diff} to {_t1} - {_t2}
    {_diff} is greater than {_t3}:
        return 1

    set {_fraction} to {_diff} / {_t3}
    scriptDebugBroadcastType("fractionOfEffectRun", "fractionOfEffectRun = %{_fraction}%")
    return {_fraction}

function drawEffects(entity: entity):

	# This shouldDraw is an optimization.
	# Particle effects only really matter to players, who can only seem them from so far away.
	# This will ensure that the script does not even attempt to draw particles around an entity
	# that no player will even see. This will allow the drawEffects to run faster.
	
	set {_shouldDraw} to false
	loop players in radius {@drawRadius} around {_entity}:
		set {_shouldDraw} to true
		exit 1 loop

	{_shouldDraw} is false:
		stop
	if hasEffect({_entity}, "invisible") is true:
		stop

	hasEffect({_entity}, "test") is true:
		show rollDice(2, 3) (flame with offset of 0.2, 0.0, 0.2) at (location of {_entity} ~ vector 0, 0.1, 0)
	hasEffect({_entity}, "test2") is true:
		loop 5 times:
			set {_x} to a random number between -0.5 and 0.5
			set {_y} to a random number between 0 and 2
			set {_z} to a random number between -0.5 and 0.5
			show dragon breath at (location of {_entity} ~ vector {_x}, {_y}, {_z})
	hasEffect({_entity}, "test3") is true:
		loop 5 times:
			set {_x} to a random number between -0.5 and 0.5
			set {_y} to 2.5
			set {_z} to a random number between -0.5 and 0.5
			show water drip at (location of {_entity} ~ vector {_x}, {_y}, {_z})
	hasEffect({_entity}, "test4") is true:
		show rollDice(3, 3) (electric spark with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "hallowed") is true:
		show rollDice(3, 3) (electric spark with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "shocking") is true:
		show rollDice(3, 3) (end rod with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "bleeding") is true:
		show rollDice(3, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "disease") is true:
		show rollDice(3, 3) (falling spore blossom with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 3, 0)
	hasEffect({_entity}, "infected") is true:
		show rollDice(10, 3) (green dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "phased") is true:
		show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
		show rollDice(10, 3) (black dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "venom") is true:
		show rollDice(10, 3) (green dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
		show rollDice(10, 3) (black dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "void") is true:
		show rollDice(10, 3) (white dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
		show rollDice(10, 3) (black dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "regen") is true:
		chance of 10%:
			show rollDice(10, 3) (heart with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, -0.5, 0)
	hasEffect({_entity}, "radiated") is true:
		chance of 10%:
			show rollDice(10, 3) (scrape with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1.5, 0)
	hasEffect({_entity}, "levitate") is true:
		show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 0)
	hasEffect({_entity}, "dark shroud") is true:
		{-rpgSkript::%{_entity}%::darkshroud} is greater than 4:
			show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector -1, 1, 0)
		{-rpgSkript::%{_entity}%::darkshroud} is greater than 3:
			show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 1, 1, 0)
		{-rpgSkript::%{_entity}%::darkshroud} is greater than 2:
			show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, -1)
		{-rpgSkript::%{_entity}%::darkshroud} is greater than 1:
			show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 1, 1)
		{-rpgSkript::%{_entity}%::darkshroud} is greater than 0:
			show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 2.5, 0)
	hasEffect({_entity}, "soulbond") is true:
		show rollDice(10, 3) (yellow dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 3, 0)
	hasEffect({_entity}, "resourceboost") is true:
		show rollDice(10, 3) (purple dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 2, 0)
	hasEffect({_entity}, "corrupting dunes") is true:
		show rollDice(10, 3) (brown dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector -1, 1, -1)
		show rollDice(10, 3) (brown dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 1, 1, 1)
		show rollDice(10, 3) (brown dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 1, 1, -1)
		show rollDice(10, 3) (brown dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector -1, 1, 1)
	hasEffect({_entity}, "rage") is true:
		show rollDice(10, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector -1, 1, -1)
		show rollDice(10, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 1, 1, 1)
		show rollDice(10, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 1, 1, -1)
		show rollDice(10, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector -1, 1, 1)
	hasEffect({_entity}, "firestorm") is true:
		show rollDice(10, 3) (orange dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 2.5, 0)
		show rollDice(10, 3) (red dust with offset of 0.3, 0.5, 0.3) at (location of {_entity} ~ vector 0, 2.5, 0)
	hasEffect({_entity}, "mana leak") is true:
		loop 5 times:
			set {_x} to a random number between -0.5 and 0.5
			set {_y} to 1.0
			set {_z} to a random number between -0.5 and 0.5
			show blue dust at (location of {_entity} ~ vector {_x}, {_y}, {_z})

command /rpgeffect <player> <text> <timespan>:
	trigger:
		command executor has permission "rpg.control"
		applyEffect(arg 1, arg 2, arg 3)

every 1 seconds:
	loop all players:
		clear loop-player's scoreboard
		set title of loop-player's scoreboard to "&eInformation"
		set line 15 of loop-player's scoreboard to "&a"
		set line 14 of loop-player's scoreboard to "&a"
		if hasClass(loop-player, "nethermancer") is false:
			set line 13 of loop-player's scoreboard to "&3 Mana: %{rpgSkript::mana::%loop-player%}% / %{rpgSkript::maxMana::%loop-player%}%"
		else:
			set line 13 of loop-player's scoreboard to "&3 Mana & Heat Level: %{rpgSkript::mana::%loop-player%}% / %{rpgSkript::maxMana::%loop-player%}% & %{rpgSkript::heat::%loop-player%}% / 1000"
		if at least one of:
			hasClass(loop-player, "barbarian") is true
			hasClass(loop-player, "warrior") is true
			hasClass(loop-player, "rogue") is true
			hasClass(loop-player, "monk") is true
		then:
			set line 12 of loop-player's scoreboard to "&4 Energy: %{rpgSkript::%loop-player%::Energy}% / %{rpgSkript::%loop-player%::maxEnergy}%"
		calculateMaxMinions(loop-player) > 0:
			set line 11 of loop-player's scoreboard to "&d Minions: %getMinionCount(loop-player)% / %calculateMaxMinions(loop-player)%"

		hasClass(loop-player, "druid") is true:
			set line 10 of loop-player's scoreboard to "&6 Wildshape: %{rpgSkript::%loop-player%::wildshape}% / %{rpgSkript::%loop-player%::maxWildshape}%"
			if {rpgSkript::%loop-player%::batshape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Bat"
			else if {rpgSkript::%loop-player%::wolfshape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Wolf"
			else if {rpgSkript::%loop-player%::spidershape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Spider"
			else if {rpgSkript::%loop-player%::horseshape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Horse"
			else if {rpgSkript::%loop-player%::bearshape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Bear"
			else if {rpgSkript::%loop-player%::humanshape} is true:
				set line 9 of loop-player's scoreboard to "&a Current Form: Human"

		hasClass(loop-player, "rogue") is true:
			set line 8 of loop-player's scoreboard to " Monsters: %countEntities(monsters within 20 meters of loop-player)%"
			set line 7 of loop-player's scoreboard to " Animals: %countEntities(animals within 30 meters of loop-player)%"
			set line 6 of loop-player's scoreboard to " Players: %countEntities(players within 50 meters of loop-player)%"
			set line 5 of loop-player's scoreboard to " Items on Ground: %countEntities(dropped items within 30 meters of loop-player)%"

		if getLevel(loop-player) is less than 100:
			set line 1 of loop-player's scoreboard to "&b LVL / XP : &f%getLevel(loop-player)% & %getXP(loop-player)% &b/&f %calculateXPForLevel(loop-player)%"
		else:
			set line 1 of loop-player's scoreboard to "&b LVL: &f%getLevel(loop-player)%"
			
every 4 ticks:
	loop all players:
		drawEffects(loop-player)
		loop all mobs in radius {@drawRadius} of loop-player:
			loop-mob is alive
			{_drawn::%uuid of loop-entity-2%} is not set:
				drawEffects(loop-entity-2)
				set {_drawn::%uuid of loop-entity-2%} to 0

		hasEffect(loop-player, "radiated") is true:
			set {_fraction} to fractionOfEffectRun(loop-player, "radiated")
			set {_m} to 0.5 + 0.5 * sin(90 * {_fraction})
			scriptDebugBroadcastType("radiated", "{_m} = %{_m}%")
			set {_hplimit} to {_m} * the maximum health of loop-player
			scriptDebugBroadcastType("radiated", "{_hplimit} of %loop-player% is now %{_hplimit}%")
			scriptDebugBroadcastType("health", "{_hplimit} of %loop-player% is now %{_hplimit}%")
			if health of loop-entity is greater than {_hplimit}:
				set health of loop-entity to {_hplimit}
				scriptDebugBroadcastType("radiated", "Lowering health of %loop-player% due to Radiation to %{_hplimit}%")
				scriptDebugBroadcastType("health", "Lowering health of %loop-player% due to Radiation to %{_hplimit}%")
			set {_dmg} to a random number between 1 and 2.5
			chance of 2%:
				hasImbue(loop-player, "radiation") is false
				set health of loop-player to health of loop-player - {_dmg}

		if {-rpgSkript::%loop-player%::float} is true:
			apply levitation without particles to the loop-player for 2 seconds replacing the existing effect

every 1 seconds:
	loop all entities:
		loop-entity is alive
		set {_effectDamage} to 0
		set {_ndamage} to {_effectDamage}
		set {_odamage} to {_effectDamage}
		hasEffect(loop-entity, "firestorm") is true:
			if:
				isMinion(loop-entity) is false
				hasClass(loop-entity, "nethermancer") is false
				hasClass(getSummoner(uuid of loop-entity), "nethermancer") is false
			then:
				loop-entity is not a dropped item
				ignite loop-entity
				wait 1 tick
				if loop-entity is on fire:
					set {_effectDamage} to {_effectDamage} + 1.5
					scriptDebugBroadcastType("firestorm", "Damaging %loop-entity% by 1.5")
					loop players in radius 15 around loop-entity:
						hasClass(loop-player, "nethermancer") is true:
							heal(loop-player, 0.1)
							scriptDebugBroadcastType("firestorm", "Healing Nethermancer %loop-player%")
				loop all entities in radius 1.5 around loop-entity:
					chance of 50%:
						isMinion(loop-entity-2) is false
						loop-entity-2 is not a player
						loop-entity-2 is not loop-entity-1
						applyEffect(loop-entity-2, "firestorm", 10 seconds)
						scriptDebugBroadcastType("firestorm", "Spreading from %loop-entity-1% to %loop-entity-2%")
		hasEffect(loop-entity, "hallowed") is true:
			if isMonster(loop-entity) is true:
				set {_effectDamage} to {_effectDamage} + 1
				scriptDebugBroadcastType("hallowed", "Damaging Monster %loop-entity% by 1")
			else if hasClass(loop-entity, "paladin") is true:
				heal(loop-entity, 0.5)
				scriptDebugBroadcastType("hallowed", "Healing Paladin %loop-entity% by 0.5")
			else:
				set {_effectDamage} to {_effectDamage} + 0.5
				scriptDebugBroadcastType("hallowed", "Damaging Non-Monster %loop-entity% by 0.5")
		hasEffect(loop-entity, "bleeding") is true:
			if hasClass(loop-entity, "warrior") is false:
				set {_bleed} to 0.025 * maximum health of loop-entity 
				set {_effectDamage} to {_effectDamage} + {_bleed}
				scriptDebugBroadcastType("bleeding", "Damaging Non-Warrior %loop-entity% by %{_bleed}%")
		hasEffect(loop-entity, "mana leak") is true:
			loop-entity is a player
			set {_loss} to ({rpgSkript::maxMana::%loop-entity%} / 40) / 2
			subMana(loop-entity, {_loss}, false)
			scriptDebugBroadcastType("mana_leak", "Taking away %({rpgSkript::maxMana::%loop-entity%} / 40) / 2% Mana from %loop-entity%")
		hasEffect(loop-entity, "venom") is true:
			chance of 10%:
				set {_dmg} to a random number between 2.5 and 7.5
				set {_effectDamage} to {_effectDamage} + {_dmg}
				apply weakness 1 without particles to the loop-entity for 2 seconds replacing the existing effect
				applyEffect(loop-entity, "vulnerable", 7.5 seconds)
		hasEffect(loop-entity, "cacooned") is true:
			apply weakness 2 without particles to the loop-entity for 2 seconds replacing the existing effect
			apply slowness 255 without particles to the loop-entity for 2 seconds replacing the existing effect
			apply blindness 1 without particles to the loop-entity for 2 seconds replacing the existing effect
			set {_effectDamage} to {_effectDamage} + 0.5
			applyEffect(loop-entity, "vulnerable", 7.5 seconds)				
			chance of 33%:
				spawn 1 cave spider at loop-entity:
					set movement speed attribute of the spider to 3 * movement speed attribute of the cave spider
					set attack damage attribute of the spider to 0.75 * attack damage attribute of the cave spider
					set maximum health of the spider to 2.5						
		hasEffect(loop-entity, "shocking") is true:
			apply slowness 255 without particles to the loop-entity for 2 seconds replacing the existing effect
			loop all entities in radius 5 around loop-entity:
				loop-entity-2 is not loop-entity-1
				hasEffect(loop-entity-2, "shocking") is false
				set {_effectDamage} to {_effectDamage} + 1
				scriptDebugBroadcastType("shocking", "Damaging %loop-entity-2% by 1")
				applyEffect(loop-entity-2, "shocking", 0.1 seconds)
				set {_vec} to vector between loop-entity-1 and loop-entity-2
				set y component of {_vec} to 0
				set {_vec} to normalized {_vec}
				push loop-entity-2 {_vec} with force 1.4
				push loop-entity-2 upwards with force 0.8
				chance of 30%:
					hasEffect(loop-entity-2, "shocking") is false:
						applyEffect(loop-entity-2, "shocking", 2 seconds)
		hasEffect(loop-entity, "disease") is true:
			hasClass(loop-entity, "paladin") is false
			loop-entity is not a zombie
			loop-entity is not a skeleton
			chance of 10%:
				set {_effectDamage} to {_effectDamage} + 2.5
				scriptDebugBroadcastType("disease", "Damaging Non-Paladin Non-Zombie/Skeleton %loop-entity% by 2.5")
			loop all entities in radius 5 around loop-entity:
				loop-entity-2 is not loop-entity-1
				loop-entity-2 is alive
				chance of 30%:
					applyEffect(loop-entity-2, "disease", 30 seconds)
					scriptDebugBroadcastType("disease", "Spreading from %loop-entity-1% to %loop-entity-2%")

		hasEffect(loop-entity, "void") is true:
			apply glowing 1 without particles to the loop-entity for 5 seconds replacing the existing effect

		hasEffect(loop-entity, "invisible") is true:
			apply invisibility 1 without particles to the loop-entity for 5 seconds replacing the existing effect
			hasImbue(loop-entity, "spidersilk") is true:
				light level at loop-entity is less than 11
				applyEffect(loop-entity, "invisible", 5 seconds)			
			hasClass(loop-entity, "rogue") is true:
				apply swiftness 4 without particles to the loop-entity for 5 seconds replacing the existing effect
				light level at loop-entity is less than 11
				applyEffect(loop-entity, "invisible", 5 seconds)
				scriptDebugBroadcastType("rogue", "Resetting Rogue Invisibility")
			loop all monsters in radius 10 of loop-entity:
				target of loop-monster is loop-entity-1:
					reset target of loop-monster

		hasEffect(loop-entity, "levitate") is true:
			apply levitation 1 without particles to the loop-entity for 5 seconds replacing the existing effect
			applyEffect(loop-entity, "vulnerable", 5 seconds)

		hasEffect(loop-entity, "corrupting dunes") is true:
			apply slowness 1 without particles to the loop-entity for 5 seconds replacing the existing effect
			apply weakness 1 without particles to the loop-entity for 5 seconds replacing the existing effect

		hasEffect(loop-entity, "soulbond") is true:
			applyEffect(loop-entity,"regen", 5 seconds)
			chance of 10%:
				apply saturation 1 without particles to the loop-entity for 5 seconds replacing the existing effect
		hasEffect(loop-entity, "soulbond") is false:
			set {-rpgSkript::%loop-entity%::soulbond} to false
			set {-rpgSkript::%loop-entity%::soulbondplayer} to false

		hasEffect(loop-entity, "rage") is true:
			applyEffect(loop-entity, "regen", 5 seconds)
			apply resistance 1 without particles to loop-entity for 5 seconds replacing the existing effect
			apply swiftness 1 without particles to loop-entity for 5 seconds replacing the existing effect
			apply strength 1 without particles to loop-entity for 5 seconds replacing the existing effect
			apply jump boost 2 without particles to loop-entity for 5 seconds replacing the existing effect

		hasEffect(loop-entity, "regen") is true:
			if hasEffect(loop-entity, "recentcombat") is true:
				heal(loop-entity, 0.05 * maximum health of loop-entity)
				scriptDebugBroadcastType("regen", "Regenerating %loop-entity% for %0.05 * maximum health of loop-entity% of %maximum health of loop-entity% health")
			else:
				heal(loop-entity, 0.1 * maximum health of loop-entity)
				scriptDebugBroadcastType("regen", "Regenerating %loop-entity% for %0.1 * maximum health of loop-entity% of %maximum health of loop-entity% health")

		{-severestorms} is true:
			isFriendlyMob(loop-entity) is false
			if at least one of:
				biome of loop-entity is desert
				biome of loop-entity is badlands
			then:
				if sunlight level at loop-entity is greater than 10:
					apply weakness 1 without particles to the loop-entity for 5 seconds replacing the existing effect
					apply slowness 2 without particles to the loop-entity for 5 seconds replacing the existing effect				
					apply blindness 1 without particles to the loop-entity for 5 seconds replacing the existing effect
					chance of 10%:
						set {_effectDamage} to {_effectDamage} + 0.75
						scriptDebugBroadcastType("worldevents", "Damaging %loop-entity% by 0.75 from Sandstorm")						
			else:
				sunlight level at loop-entity is greater than or equal to 15
				if isWearingNothing(loop-entity) is true:
					set {_effectDamage} to {_effectDamage} + 1
					scriptDebugBroadcastType("worldevents", "Damaging %loop-entity% by 1 from Acid Rain")	
				else if isWearingLightOrLess(loop-entity) is true:
					set {_effectDamage} to {_effectDamage} + 0.75
					scriptDebugBroadcastType("worldevents", "Damaging %loop-entity% by 0.75 from Acid Rain")	
				else:
					set {_effectDamage} to {_effectDamage} + 0.5
					scriptDebugBroadcastType("worldevents", "Damaging %loop-entity% by 0.5 from Acid Rain")				

		hasClass(loop-entity, "monk") is true:
			set {_effectDamage} to {_effectDamage} * 0.65
			scriptDebugBroadcastType("monk", "Reducing Effect Damage by *0.65 on %loop-entity%")

		hasClass(loop-entity, "paladin") is true:
			set {_effectDamage} to {_effectDamage} * 0.9
			scriptDebugBroadcastType("paladin", "Reducing Effect Damage by *0.9 on %loop-entity%")

		if hasEffect(loop-entity, "shielded") is true:
			set {_effectDamage} to 0
			scriptDebugBroadcastType("shielded", "Reducing Effect Damage to 0 on %loop-entity%")
			stop
			
		if {_effectDamage} is not 0:
			set {_reduction} to 1 - (0.15 * countImbue(loop-entity, "iron will") )
			set {_effectDamage} to {_effectDamage} * {_reduction}
			scriptDebugBroadcastType("iron_will", "Reducing Effect Damage by *%{_reduction}% on %loop-entity%")
			
			if {-evilSkript::%loop-entity%::isBoss} is false:
				set health of loop-entity to health of loop-entity - {_effectDamage} * {_reduction}
			else:
				set health of loop-entity to health of loop-entity - ({_effectDamage} * {_reduction}) * 0.5
				scriptDebugBroadcastType("boss_mob", "Reducing Effect Damage by 0.5 on %loop-entity%")

			scriptDebugBroadcastType("effect", "Reducing Health of %loop-entity% by %{_effectDamage}%")
			




every 2 seconds:

	arcaneTide()

	loop all players:
		setMaxHealth(loop-player)

		setupMana(loop-player)
		regenMana(loop-player)

		setupEnergy(loop-player)
		regenEnergy(loop-player)
		
		setupWildshape(loop-player)

		cullMinions(loop-player)
		
		hasClass(loop-player, "wizard") is true:
			if hasResearch(loop-player, "power") is true:
				add 3 experience to loop-player
		hasClass(loop-player, "warrior") is true:
			heal(loop-player, 1)
			loop-player's knockback resistance attribute is not 0.7:
				set loop-player's knockback resistance attribute to 0.7
			apply haste 2 without particles to the loop-player for 30 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 30 seconds replacing the existing effect
		hasClass(loop-player, "paladin") is true:
			heal(loop-player, 2)
			loop entities in radius 50 of loop-player:
				isMonster(loop-entity-2) is true
				loop-entity-2 is not loop-player
				apply slowness 1 to the loop-entity-2 for 20 seconds replacing the existing effect
				apply weakness 1 to the loop-entity-2 for 20 seconds replacing the existing effect
				chance of 30%:
					applyEffect(loop-entity-2, "hallowed", 8 seconds)
		hasClass(loop-player, "nethermancer") is true:
			loop-player is in lava:
				heal(loop-player, 1)
			loop-player is on fire:
				heal(loop-player, 0.5)
			subMana(loop-player, 20, false) is true:
				if {rpgSkript::heat::%loop-player%} is less than 500:
					loop all entities in radius {rpgSkript::heat::%loop-player%} / 100 around loop-player:
						loop-entity-2 is not loop-player
						isMonster(loop-entity-2) is true
						ignite loop-entity-2
						regenHeat(loop-player, -3)
				else:
					loop all entities in radius {rpgSkript::heat::%loop-player%} / 50 around loop-player:
						loop-entity-2 is not loop-player
						isMonster(loop-entity-2) is true
						isMinion(loop-entity-2) is false
						applyEffect(loop-entity-2, "firestorm", 10 seconds)
						regenHeat(loop-player, -5)
						
		hasClass(loop-player, "herobrine") is true:
			heal(loop-player, 2)
			loop-player's knockback resistance attribute is not 0.9:
				set loop-player's knockback resistance attribute to 0.9
			apply haste 6 without particles to the loop-player for 30 seconds replacing the existing effect
			apply strength 4 without particles to the loop-player for 30 seconds replacing the existing effect
		hasClass(loop-player, "barbarian") is true:
			canUseBarbarianAbilities(loop-player) is true:
				set {rpgSkript::%loop-player%::barbenemies} to 0
				loop all entities in radius 10 around loop-player:
					loop-entity-2 is not loop-player
					set {rpgSkript::%loop-player%::barbenemies} to {rpgSkript::%loop-player%::barbenemies} + 1
				if {rpgSkript::%loop-player%::barbenemies} is greater than 4:
					chance of 50%:
						rageTrigger(loop-player)
					
					
		hasClass(loop-player, "necromancer") is true:
			if {rpgSkript::%loop-player%::ritualstrcount} is greater than 0:
				set {rpgSkript::%loop-player%::ritualstrcount} to {rpgSkript::%loop-player%::ritualstrcount} - 2
				scriptDebugBroadcastType("ritual", "%loop-player%: Strengthen Count -> %{rpgSkript::%loop-player%::ritualstrcount}%")
			else:
				set {rpgSkript::%loop-player%::ritualstrcount} to 0
				set {rpgSkript::%loop-player%::ritualstr} to false
				scriptDebugBroadcastType("ritual", "%loop-player%: Strengthen Boolean -> %{rpgSkript::%loop-player%::ritualstr}%")
			if {rpgSkript::%loop-player%::ritualmincount} is greater than 0:
				set {rpgSkript::%loop-player%::ritualmincount} to {rpgSkript::%loop-player%::ritualmincount} - 2
				scriptDebugBroadcastType("ritual", "%loop-player%: Minion Count -> %{rpgSkript::%loop-player%::ritualstrcount}%")
			else:
				set {rpgSkript::%loop-player%::ritualmincount} to 0
				set {rpgSkript::%loop-player%::ritualmin} to false
				scriptDebugBroadcastType("ritual", "%loop-player%: Minion Boolean -> %{rpgSkript::%loop-player%::ritualstr}%")
			if {rpgSkript::%loop-player%::ritualcorcount} is greater than 0:
				set {rpgSkript::%loop-player%::ritualcorcount} to {rpgSkript::%loop-player%::ritualcorcount} - 2
			else:
				set {rpgSkript::%loop-player%::ritualcorcount} to 0
				set {rpgSkript::%loop-player%::ritualcor} to false

			if {rpgSkript::%loop-player%::ritualmin} is true:
				loop all entities in radius 20 around loop-player:
					loop-entity-2 is not loop-player:
						isMinion(loop-entity-2) is true:
							getSummoner(uuid of loop-entity-2) is loop-player:
								apply haste 1 without particles to loop-entity-2 for 30 seconds replacing the existing effect
								apply strength 2 without particles to loop-entity-2 for 30 seconds replacing the existing effect
								apply resistance 1 without particles to loop-entity-2 for 30 seconds replacing the existing effect
								apply swiftness 1 without particles to loop-entity-2 for 30 seconds replacing the existing effect
								applyEffect(loop-entity-2, "regen", 30 seconds)
								apply absorption 1 without particles to loop-entity-2 for 30 seconds replacing the existing effect

					
		hasClass(loop-player, "druid") is true:
			time in world of loop-player is between 23:00 and 1:00:
				regenWildshape(loop-player)
			block at loop-player is water:
				apply dolphin's grace to loop-player for 5 seconds replacing the existing effect
				apply water breathing to loop-player for 5 seconds replacing the existing effect

			if {rpgSkript::%loop-player%::batshape} is not set:
				set {rpgSkript::%loop-player%::batshape} to false
			if {rpgSkript::%loop-player%::bearshape} is not set:
				set {rpgSkript::%loop-player%::bearshape} to false
			if {rpgSkript::%loop-player%::wolfshape} is not set:
				set {rpgSkript::%loop-player%::wolfshape} to false
			if {rpgSkript::%loop-player%::horseshape} is not set:
				set {rpgSkript::%loop-player%::horseshape} to false
			if {rpgSkript::%loop-player%::spidershape} is not set:
				set {rpgSkript::%loop-player%::spidershape} to false
			if {rpgSkript::%loop-player%::humanshape} is not set:
				set {rpgSkript::%loop-player%::humanshape} to true

			if canUseShapeshiftAbilities(loop-player) is true:
				if {rpgSkript::%loop-player%::batshape} is true:
					if light level at loop-player is greater than 10:
						apply blindness 2 without particles to the loop-player for 10 seconds replacing the existing effect
					else:
						apply night vision 2 without particles to the loop-player for 10 seconds replacing the existing effect
				if {rpgSkript::%loop-player%::wolfshape} is true:
					apply night vision 2 without particles to the loop-player for 10 seconds replacing the existing effect
					apply swiftness 1 without particles to the loop-player for 3 seconds replacing the existing effect
				if {rpgSkript::%loop-player%::horseshape} is true:
					apply swiftness 2 without particles to the loop-player for 3 seconds replacing the existing effect
					apply jump boost 2 without particles to the loop-player for 3 seconds replacing the existing effect
				if {rpgSkript::%loop-player%::bearshape} is true:
					apply strength 2 without particles to the loop-player for 3 seconds replacing the existing effect
			else:
				set {rpgSkript::%loop-player%::bearshape} to false
				set {rpgSkript::%loop-player%::horseshape} to false
				set {rpgSkript::%loop-player%::spidershape} to false
				set {rpgSkript::%loop-player%::wolfshape} to false
				set {rpgSkript::%loop-player%::batshape} to false
				set {rpgSkript::%loop-player%::humanshape} to true

			canUseDruidAbilities(loop-player) is true:	
				loop all blocks in radius 5 around loop-player:
					if loop-block is a flower:
						applyEffect(loop-player, "regen", 3 seconds)

		hasClass(loop-player, "artificer") is true:
			if {-rpgSkript::%loop-player%::mineLocation} is set:
				if {-rpgSkript::%loop-player%::mineAuto} is true:
					loop all entities in radius 5 around {-rpgSkript::%loop-player%::mineLocation}:
						isMonster(loop-entity-2) is true:
							make loop-player execute command "/activate mine"

		if time in world of loop-player is between 19:00 and 5:00:
			{rpgSkript::%loop-player%::lastButcher} is not set:
				set {rpgSkript::%loop-player%::lastButcher} to 30 minutes ago
			difference between {rpgSkript::%loop-player%::lastButcher} and now is more than 1 hour:
				set {rpgSkript::%loop-player%::lastButcher} to now
				set {_chance} to log({rpgdiff}) * 12.5 / 100
				if {_chance} > 0:
					chance of {_chance}:
						scriptDebugBroadcastType("difficulty", "Attempting to spawn a butcher at %{_chance}% chance with %{rpgdiff}% difficulty")
						send "&4You feel an evil presence watching... Waiting..." to loop-player
						wait 15 seconds
						summonButcher(loop-player, 100)
						
			

		if canFly(loop-player) is true:
			enable flight for loop-player
		else:
			disable flight for loop-player
		apply strength 2 without particles to the loop-player for 5 seconds replacing the existing effect

		if countImbue(loop-player, "golem") is 5:
			apply slowness 5 without particles to the loop-player for 5 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 5 seconds replacing the existing effect
		else if countImbue(loop-player, "golem") is 4:
			apply slowness 4 without particles to the loop-player for 5 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 5 seconds replacing the existing effect	
		else if countImbue(loop-player, "golem") is 3:
			apply slowness 3 without particles to the loop-player for 5 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 5 seconds replacing the existing effect
		else if hasImbue(loop-player, "guardian") is true:
			apply slowness 2 without particles to the loop-player for 5 seconds replacing the existing effect	
		else if countImbue(loop-player, "golem") is 1:
			apply slowness 1 without particles to the loop-player for 5 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 5 seconds replacing the existing effect
		else if countImbue(loop-player, "golem") is 2:
			apply slowness 2 without particles to the loop-player for 5 seconds replacing the existing effect
			apply strength 1 without particles to the loop-player for 5 seconds replacing the existing effect


		hasImbue(loop-player, "photosynthesis") is true:
			sun light level at loop-player is greater than 13:
				time in world of loop-player is not between 19:00 and 5:00:
					set {_add} to 0.25 * countImbue(loop-player, "photosynthesis")
					heal(loop-player, {_add})
		if hasImbue(loop-player, "speed") is true:
			if countImbue(loop-player, "speed") is 1:
				apply swiftness 1 without particles to the loop-player for 5 seconds replacing the existing effect
			else if countImbue(loop-player, "speed") is 2:
				apply swiftness 2 without particles to the loop-player for 5 seconds replacing the existing effect	
			else if countImbue(loop-player, "speed") is 3:
				apply swiftness 3 without particles to the loop-player for 5 seconds replacing the existing effect
			else if countImbue(loop-player, "speed") is 4:
				apply swiftness 4 without particles to the loop-player for 5 seconds replacing the existing effect	
			else if countImbue(loop-player, "speed") is 5:
				apply swiftness 5 without particles to the loop-player for 5 seconds replacing the existing effect			
		if hasImbue(loop-player, "radiation") is true:
			applyEffect(loop-player, "radiated", 60 seconds)
		if hasImbue(loop-player, "lightning rod") is true:
			loop all entities in radius 20 around loop-player:
				chance of 5%:
					isMonster(loop-entity-2) is true:
						loop-entity-2 is not a dropped item
						loop-entity-2 is alive
						create lightning effect at loop-entity-2
						apply slowness 255 to loop-entity-2 for 3 seconds replacing the existing effect
						apply glowing 1 to loop-entity-2 for 3 seconds replacing the existing effect
						damage loop-entity-2 by 10 + ({rpgSkript::maxMana::%loop-player%} / 100)
	

			
every 5 seconds:
	loop all entities:
		hasEffect(loop-entity, "phased") is true:
			loop-entity is not a enderman
			loop-entity is not a enderdragon
			loop all blocks in radius 15 around loop-entity:
				block above loop-block is air
				block 2 meters above loop-block is air
				chance of 10%:
					wait 3 ticks
					teleport loop-entity 1 meter above loop-block
					hasClass(loop-entity, "endwarden") is false:
						damage loop-entity by 0.5
					scriptDebugBroadcastType("effect", "Phased Teleport Trigger on %loop-entity%")
					send "&9You uncontrollably teleport!" to loop-entity
					stop

	loop all players:
		hasImbue(loop-player, "Anti-Gravity") is true:
			loop all entities in radius 20 around loop-player:
				isMonster(loop-entity-2) is true:
					chance of 50%:
						damage loop-entity-2 by 5
						applyEffect(loop-entity-2, "levitate", 5 seconds)

		if hasImbue(loop-player, "inspirational") is true:
			loop all entities in radius 10 around loop-player:
				isMonster(loop-entity-2) is false
				applyEffect(loop-entity-2, "inspired", 15 seconds)
						
		hasImbue(loop-player, "Raid Leader") is true:	
			getMinionCount(loop-player) is not equal to calculateMaxMinions(loop-player)
			if {-rpgSkript::%loop-player%::raidOrder} is not set:
				set {-rpgSkript::%loop-player%::raidOrder} to 1
			set {_player} to loop-player
			if {-rpgSkript::%loop-player%::raidOrder} is 1:
				spawn 1 pillager at loop-player:
					setupMinion(the pillager, {_player})
					set held item of the pillager to crossbow
				set {-rpgSkript::%loop-player%::raidOrder} to {-rpgSkript::%loop-player%::raidOrder} + 1
			else if {-rpgSkript::%loop-player%::raidOrder} is 2:
				spawn 1 vindicator at loop-player:
					setupMinion(the vindicator, {_player})
				set {-rpgSkript::%loop-player%::raidOrder} to {-rpgSkript::%loop-player%::raidOrder} + 1
			else:
				spawn 1 pillager at loop-player:
					setupMinion(the pillager, {_player})
					set {_entity} to the pillager
					set {-rpgSkript::%{_entity}%::raidMage} to true
					set held item of the pillager to air
				set {-rpgSkript::%loop-player%::raidOrder} to {-rpgSkript::%loop-player%::raidOrder} + 1
			if {-rpgSkript::%loop-player%::raidOrder} is greater than 3:
				set {-rpgSkript::%loop-player%::raidOrder} to 1
			loop getMinions({_player}):
				apply strength 2 without particles to the loop-value-2 for 15 seconds replacing the existing effect
				apply swiftness 2 without particles to the loop-value-2 for 15 seconds replacing the existing effect
				apply jump boost 2 without particles to the loop-value-2 for 15 seconds replacing the existing effect
				applyEffect(loop-value-2, "regen", 15 seconds)
				loop-value-2 is a pillager
				{-rpgSkript::%loop-value-2%::raidMage} is true:
					loop entities in radius 10 around loop-value-2:
						chance of 50%:
							isMonster(loop-entity-3) is true
							loop-entity-3 is not a dropped item
							loop-entity-3 is alive
							create lightning effect at loop-entity-3
							apply slowness 255 to loop-entity-3 for 3 seconds replacing the existing effect
							apply glowing 1 to loop-entity-3 for 3 seconds replacing the existing effect
							applyEffect(loop-entity-3, "vulnerable", 3 seconds)
							damage loop-entity-3 by 15 * calculateCoreStatBonus(loop-player, "minion")
							exit 1 loop

			
			
	
function getTag(item: item, name: text) :: text:
	set {_value} to tag {_name} of nbt of {_item}
	scriptDebugBroadcastType("tag", "%{_item}% tag %{_name}%: %{_value}%")
	return {_value}

function becomeZombie( entity: entity):
	spawn a zombie at {_entity}:
		set {_zombie} to the zombie
		set {rpgSkript::risenDead::%{_zombie}%} to true
		if {_entity} is a player:
			set the zombie's display name to "&4Zombie %{_entity}%"
		set attack damage attribute of the zombie to the attack damage attribute of {_entity}
		set movement speed attribute of the zombie to 1.5 * the movement speed attribute of the zombie
		set maximum health of the zombie to the maximum health of {_entity}
		set the zombie's held item to {_entity}'s held item
		set the zombie's off hand item to {_entity}'s off hand item
		set the zombie's helmet to {_entity}'s helmet
		set the zombie's chestplate to {_entity}'s chestplate
		set the zombie's leggings to {_entity}'s leggings
		set the zombie's boots to {_entity}'s boots
		heal the zombie

on right click with glass bottle:
	hasLore(event-player's held item, "holding") is true
	cancel the event
	set {_id} to getTag(event-player's held item, "holdingId")
	scriptDebugBroadcastType("holding", "ID: %{_id}%")
	if {_id} is not set:
		scriptDebugBroadcastType("holding", "ID not set, creating new holding inventory")
		set {_id} to a random UUID
		{rpgSkript::holding::%{_id}%} is not set:
			scriptDebugBroadcastType("holding", "New ID: %{_id}%")
			set {rpgSkript::holding::%{_id}%} to 1
			set tag "holdingId" of nbt of event-player's held item to {_id}
	set {_inv} to chest inventory with 6 rows named "&eBottle of Holding"
	loop 6*9 times:
		set slot (loop-value)-1 of {_inv} to {rpgSkript::holding::%{_id}%::%loop-value%}
	open {_inv} to player

on inventory close:
	if event-inventory's name is "&eBottle of Holding":
		set {_id} to getTag(player's held item, "holdingId")
		{_id} is not set:
			scriptDebugBroadcastType("holding", "ID not set, cannot save inventory")
		loop 6*9 times:
			set {rpgSkript::holding::%{_id}%::%loop-value%} to slot (loop-value)-1 of event-inventory


on death:

	hasEffect(victim, "soulbond") is true:
		removeEffect( {rpgSkript::%victim%::soulbondplayer} , "soulbond")
		set {-rpgSkript::%victim%::soulbond} to false
		set {-rpgSkript::%victim%::soulbondplayer} to false
		set {-rpgSkript::%{rpgSkript::%victim%::soulbondplayer}%::soulbond} to false
		set {-rpgSkript::%{rpgSkript::%victim%::soulbondplayer}%::soulbondplayer} to false
		
	hasEffect(victim, "infected") is true:
		isMonster(victim) is false
		victim is not an animal
		isMinion(victim) is false
		isFriendlyMob(victim) is false
		becomeZombie(victim)

	hasEffect(victim, "firestorm") is true:
		set {_range} to 0.04 * maximum health of victim
		if {_range} is greater than 10:
			set {_range} to 10
		loop all entities in radius {_range} around victim:
			if loop-entity is alive:
				if:
					isMinion(loop-entity) is false
					loop-entity is not a player
					hasClass(loop-entity, "nethermancer") is false
					hasClass(getSummoner(uuid of loop-entity), "nethermancer") is false
				then:
					loop-entity is not a dropped item
					isFriendlyMob(loop-entity) is false
					damage loop-entity by {_range} / 4
					chance of 50%:
						loop-entity is not a player
						applyEffect(loop-entity, "firestorm", 10 seconds)
					set {_vec} to vector between victim and loop-entity
					set y component of {_vec} to 0
					set {_vec} to normalized {_vec}
					push loop-entity {_vec} with force 0.2 * {_range}
					push loop-entity upwards with force 0.1 * {_range}
			create a fake explosion at the victim

	if {rpgSkript::heat::%victim%} is set:
		set {rpgSkript::heat::%victim%} to 0
		
	removeAllEffects(victim)
	
	isMonster(victim) is true:
		chance of (2+({rpgdiff}/5))%:
			set {_item} to generateRandomLoot()
			hasAnyImbue({_item}) is true:
				scriptDebugBroadcastType("loot", "Added %{_item}% to mob loot")
				add {_item} to the drops

	if hasClass(attacker, "necromancer") is true:
		if {rpgSkript::%attacker%::ritualcor} is true:
			createWorldEffect(block at victim, "blight", 10 seconds, attacker)
			if victim is a skeleton:
				chance of 30%:
					add 2 bone to the drops
			if victim is a zombie:
				chance of 30%:
					add 2 rotten flesh to the drops
			if victim is a spider:
				chance of 30%:
					add 1 spider eye to the drops
	else if isMinion(attacker) is true:
		if hasClass( getSummoner(uuid of attacker), "necromancer") is true:
			set {_summoner} to getSummoner(uuid of attacker)
			if {rpgSkript::%{_summoner}%::ritualcor} is true:
				createWorldEffect(block at victim, "blight", 10 seconds, getSummoner(uuid of attacker))
				if victim is a skeleton:
					chance of 30%:
						add 2 bone to the drops
				if victim is a zombie:
					chance of 30%:
						add 2 rotten flesh to the drops
				if victim is a spider:
					chance of 30%:
						add 1 spider eye to the drops
		




on experience change:
	hasImbue(event-player, "enlighten") is true:
		while true is true:
			wait 10 ticks
			chance of 60%:
				add 1 experience to event-player
			else:
				exit 1 loop
	hasEffect(event-player, "soulbond") is true:
		add 2 experience to {-rpgSkript::%event-player%::soulbondplayer}

on damage:
	set {_odamage} to the damage
	{commandSkript::%victim%::isTrainingDummy} is true:
		send "&6You hit the dummy for %{_odamage}% points of damage!" to the attacker
	set {_ndamage} to the damage

	hasEffect(victim, "vulnerable") is true:
		set the damage to the damage * 2
	hasImbue(victim, "Subdue to Anger") is true:
		set the damage to the damage * 1.50
	hasEffect(victim, "inspired") is true:
		set the damage to the damage * 0.9
	hasEffect(attacker, "inspired") is true:
		set the damage to the damage * 1.1
	{-evilSkript::%attacker%::isBoss} is true:
		event-projectile is set:
			set the damage to the damage * (1.1^({rpgdiff} - 1))
	{-evilSkript::%attacker%::HeadHunter} is true:
		event-projectile is set:
			set the damage to the damage * 1.20
		chance of 30%:
			applyEffect(victim, "vulnerable", 10 seconds)
			loop all entities in radius 10 around victim:
				if at least one of:
					isMinion(loop-entity) is true
					loop-entity is a player
				then:
					loop-entity is not victim
					damage loop-entity by the damage / 2
	{-evilSkript::%attacker%::RotWalker} is true:
		chance of 40%:
			applyEffect(victim, "radiated", 1 minute)
			scriptDebugBroadcastType("health", "%victim% now has Radiated for 1 minute")
	{-evilSkript::%attacker%::isButcher} is true:
		chance of 50%:
			applyEffect(victim, "bleeding", 5 seconds)
			apply slowness 1 to victim for 5 seconds replacing the existing effect				
			apply weakness 1 to victim for 5 seconds replacing the existing effect
      

	hasEffect(victim, "shielded") is true:
		set the damage to the damage * 0.5
		set {_ndamage} to the damage
		scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Shielded Damage Reduction x0.5 -> %{_ndamage}%")
		set {_odamage} to the damage

	hasEffect(victim, "void") is true:
		set the damage to the damage * 1.5
		set {_ndamage} to the damage
		scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Void Damage Bonus x1.5 -> %{_ndamage}%")
		set {_odamage} to the damage
	hasEffect(victim, "levitate") is true:
		set the damage to the damage * 1.5
		set {_ndamage} to the damage
		scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Levitate Damage Bonus x1.5 -> %{_ndamage}%")
		set {_odamage} to the damage
	hasEffect(attacker, "invisible") is true:
		set the damage to the damage * 1.5
		set {_ndamage} to the damage
		scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Invisibility Damage Bonus x1.5 -> %{_ndamage}%")
		set {_odamage} to the damage
		removeEffect(attacker, "invisible")
	hasEffect(attacker, "spirit") is true:
		cancel the event
	hasEffect(victim, "spirit") is true:
		cancel the event
	
	damage cause is fall:
		loop all entities in radius 15 around victim:
			hasClass( loop-entity, "endwarden") is true:
				canUseEndwardenAbilities( loop-entity ) is true:
					hasClass( victim, "endwarden") is false:
						set the damage to the damage * 1.3
						set {_ndamage} to the damage
						scriptDebugBroadcastType("endwardendamage", "%{_odamage}%: EndWarden Fall x1.3 -> %{_ndamage}%")
						set {_odamage} to the damage
						exit 1 loop

	isMonster(attacker) is true:
		if at least one of:
			attacker is a zombie
			attacker is a husk
		then:
			chance of 15%:
				applyEffect(victim, "infected", 30 minutes)
			if hasEffect(victim, "infected") is true:
				set the damage to the damage * 1.2
				set {_ndamage} to the damage
				scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Zombie Infected Damage Bonus x1.2 -> %{_ndamage}%")
				set {_odamage} to the damage
		if {-evilSkript::%attacker%::dunerev} is true:
			applyEffect(victim,"Corrupting Dunes", 30 seconds)

		loop players in radius 15 around victim:
			loop-player is not victim
			hasClass(loop-player, "paladin") is true:
				set the damage to the damage * 0.85
				set {_ndamage} to the damage
				scriptDebugBroadcastType("paladindamage", "%{_odamage}%: Friendly Paladin Damage Resistance x0.85 -> %{_ndamage}%")
				set {_odamage} to the damage

	isMonster(attacker) is true:
		attacker is an enderman:
			chance of 35%:
				applyEffect(victim, "phased", 20 seconds)
			if hasEffect(victim, "phased") is true:
				hasClass(victim, "endwarden") is false
				set the damage to the damage * 1.5
				set {_ndamage} to the damage
				scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Enderman Phased Damage Bonus x1.2 -> %{_ndamage}%")
				set {_odamage} to the damage

	isMonster(victim) is true:
		victim's off hand item is a shield:
			set the damage to the damage * 0.75
		{-evilSkript::%victim%::isBoss} is true:
			set the damage to the damage * 0.25
			

	isMinion(attacker) is true:
		isMinion(victim) is true:
			hasSameSummoner(attacker, victim) is true:
				cancel the event
				stop
		else:
			isMonster(victim) is true:
				the victim is not a creeper:
					set the target of the victim to the attacker
			getSummoner(uuid of the attacker) is the victim:
				cancel the event
				stop
		if at least one of:
			attacker's held item is a bow
			attacker's held item is a crossbow
		then:
			event-projectile is set:
				set the damage to the damage * (1.2^(level of {_caster} /10))
		attacker is a spider:
			if victim has potion effect poison:
				set the damage to the damage * 1.2
				set {_ndamage} to the damage
				scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Minion Spider Poison Bonus x1.2 -> %{_ndamage}%")
				set {_odamage} to the damage
			else:
				chance of 20%:
					apply poison 1 without particles to the victim for 5 seconds replacing the existing effect
	attacker is an enderman:
		chance of 35%:
			applyEffect(victim, "phased", 20 seconds)
		if hasEffect(victim, "phased") is true:
			hasClass(victim, "endwarden") is false
			set the damage to the damage * 1.5
			set {_ndamage} to the damage
			scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Enderman Phased Damage Bonus x1.2 -> %{_ndamage}%")
			set {_odamage} to the damage
	if isMinion(victim) is true:
		damage cause is fire:
			if hasClass(getSummoner(uuid of victim), "nethermancer") is true:
				cancel the event
				stop
				

		hasClass(getSummoner(uuid of attacker), "necromancer") is true:
			add 1 experience to getSummoner(uuid of attacker)

	attacker is a player:

		set the damage to the damage * calculateCoreStatBonus(attacker, "damage")

		hasClass(attacker, "nethermancer") is true:
			chance of 30%:
				applyEffect(victim, "firestorm", 10 seconds)
		hasClass(attacker, "druid") is true:
			if {rpgSkript::%attacker%::humanshape} is true:
				attacker's held item is a stick:
					set the damage to 2.0
					set {_ndamage} to the damage
					scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Stick Damage =2 -> %{_ndamage}%")
					set {_odamage} to the damage
			else:
				if attacker's held item is not air:
					cancel the event
					stop
				if {rpgSkript::%attacker%::spidershape} is true:
					if victim has potion effect poison:
						set the damage to 1.5
						set {_ndamage} to the damage
						scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Spider Poison Damage =1.5 -> %{_ndamage}%")
						set {_odamage} to the damage
					else:
						chance of 30%:
							apply poison 1 without particles to the victim for 5 seconds replacing the existing effect
				else if {rpgSkript::%attacker%::wolfshape} is true:
					set the damage to 1.5
					set {_ndamage} to the damage
					scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Wolf Damage =1.5 -> %{_ndamage}%")
					set {_odamage} to the damage
					applyEffect(victim, "bleeding", 8 seconds)
				else if {rpgSkript::%attacker%::bearshape} is true:
					set the damage to 3
					set {_ndamage} to the damage
					scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Bear Damage =3 -> %{_ndamage}%")
					set {_odamage} to the damage
				else if {rpgSkript::%attacker%::batshape} is true:
					set the damage to 0
					set {_ndamage} to the damage
					scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Bat Damage =0 -> %{_ndamage}%")
					set {_odamage} to the damage
		hasClass(attacker, "monk") is true:
			if {-rpgSkript::%attacker%::consecutiveHits} is not set:
				set {-rpgSkript::%attacker%::consecutiveHits} to 0
			canUseMonkAbilities(attacker)
			attacker's held item is air
			set the damage to the damage * 3
			if the damage is greater than 0:
				set {-rpgSkript::%attacker%::consecutiveHits} to {-rpgSkript::%attacker%::consecutiveHits} + 1
			if mod({-rpgSkript::%attacker%::consecutiveHits}, 3) is 0:
				if attacker's held item is air:
					set the damage to the damage * 2
				set {_vec} to vector between attacker and victim
				set y component of {_vec} to 0
				set {_vec} to normalized {_vec}
				push victim {_vec} with force 1
				push victim upwards with force 0.7
			else if mod({-rpgSkript::%attacker%::consecutiveHits}, 2) is 0:
				apply slowness 255 to the victim for 3 seconds replacing the existing effect
				if attacker's held item is air:
					set the damage to the damage * 1.5
			else:
				if health of attacker is equal to maximum health of attacker:
					apply absorption 3 without particles to the attacker for 10 seconds replacing the existing effect
				else:
					heal(attacker, 2)
				
		hasClass(attacker, "rogue") is true:
			canUseRogueAbilities(attacker) is true
			set the damage to the damage * 2.0
			set {_ndamage} to the damage
			scriptDebugBroadcastType("roguedamage", "%{_odamage}%: Rogue Damage Bonus x2 -> %{_ndamage}%")
			set {_odamage} to the damage
		hasClass(attacker, "herobrine") is true:
			set the damage to the damage * 3.0
			set {_ndamage} to the damage
			scriptDebugBroadcastType("herobrinedamage", "%{_odamage}%: Herobrine Damage Bonus x3 -> %{_ndamage}%")
			set {_odamage} to the damage
		hasClass(attacker, "paladin") is true:
			isMonster(victim) is true:
				set the damage to the damage * 1.4
				set {_ndamage} to the damage
				scriptDebugBroadcastType("paladindamage", "%{_odamage}%: Paladin Monster Bonus x1.4 -> %{_ndamage}%")
				set {_odamage} to the damage
				applyEffect(victim, "hallowed", 8 seconds)
		hasClass(attacker, "barbarian") is true:
			if event-projectile is set:
				set the damage to the damage * 0.65
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Projectile Reduction x0.65 -> %{_ndamage}%")
				set {_odamage} to the damage
			else if canUseBarbarianAbilities( attacker ) is true:
				if at least one of:
					attacker's off hand item is any sword
					attacker's off hand item is any axe
				then:
					set the damage to the damage * 1.25
				set {_damageboost} to 1 + ( {rpgSkript::%attacker%::barbenemies} * 0.05 )
				set the damage to the damage * ( 1.5 + {_damageboost} )
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Damage Bonus w %{rpgSkript::%attacker%::barbenemies}% nearby entities x%1.5 + {_damageboost}% -> %{_ndamage}%")
				set {_odamage} to the damage
				set {_damageboost} to 1 + ( 1 - (health of attacker / maximum health of attacker ) )
				set the damage to the damage * {_damageboost}
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Fractional Health Damage Bonus x%{_damageboost}% -> %{_ndamage}%")
				set {_odamage} to the damage
				attacker is holding air:
					set {_vec} to vector between attacker and victim
					set y component of {_vec} to 0
					set {_vec} to normalized {_vec}
					push victim {_vec} with force 1.2
					push victim upwards with force 0.8
				chance of 10%:
					applyEffect(victim, "bleeding", 5 seconds)

		#this needs to go last
		if victim is a player:
			set the damage to the damage * 0.5
	if hasLore(attacker's held item, "Gamble") is true:
		set {_ran} to a random number between 0 and 3
		set the damage to the damage * {_ran}
	if hasLore(attacker's held item, "Splinter") is true:
		chance of 30%:
			applyEffect(victim, "vulnerable", 10 seconds)
			loop all entities in radius 10 around victim:
				if at least one of:
					isMinion(loop-entity) is true
					loop-entity is a player
				then:
					loop-entity is not victim
					loop-entity is not attacker
					damage loop-entity by the damage / 2		
	if hasLore(attacker's held item, "Venom") is true:
		set the damage to the damage * 1.50
		chance of 25%:
			applyEffect(victim, "venom", 10 seconds)
	if hasLore(attacker's helmet, "Subdue to Anger") is true:
		set {_dmgboost} to a random number between 1.5 and 3
		set the damage to the damage * {_dmgboost}
	if hasLore(attacker's held item, "Endajack") is true:
		set the damage to the damage * 1.50
		set {_raneffect} to a random integer between 0 and 2
		if {_raneffect} is 1:
			applyEffect(victim, "levitate", 7.5 seconds)
		else if {_raneffect} is 2:
			applyEffect(victim, "phased", 7.5 seconds)	
	if hasLore(attacker's held item, "sacrificial") is true:
		set the damage to the damage * 5.0
		if attacker is a player:
			set health of attacker to health of attacker - (0.1 * maximum health of attacker)
			applyEffect(attacker, "antiheal", 1.5 seconds)
		chance of 75%:
			applyEffect(victim, "bleeding", 10 seconds)
			applyEffect(victim, "vulnerable", 10 seconds)
	if hasLore(attacker's held item, "butcher") is true:
		set the damage to the damage * 1.20
		chance of 50%:
			applyEffect(victim, "bleeding", 10 seconds)
			applyEffect(victim, "vulnerable", 10 seconds)
			apply slowness 255 without particles to the victim for 10 seconds replacing the existing effect
	if hasLore(attacker's held item, "vampiric") is true:
		set {_heal} to the damage * 0.1
		heal(attacker, {_heal})
	if hasLore(attacker's held item, "hallowed") is true:
		applyEffect(victim, "hallowed", 10 seconds)
	if hasLore(attacker's held item, "shocking") is true:
		applyEffect(victim, "shocking", 2 seconds)
	if hasLore(attacker's held item, "bleeding") is true:
		applyEffect(victim, "bleeding", 10 seconds)
	if hasLore(attacker's held item, "mana leak") is true:
		applyEffect(victim, "mana leak", 10 seconds)
	if hasLore(attacker's held item, "disease") is true:
		applyEffect(victim, "disease", 30 seconds)
	if hasLore(attacker's held item, "bloodied") is true:
		set {_damageboost} to 1 + ( 1 - (health of attacker / maximum health of attacker ) )
		set the damage to the damage * {_damageboost}
	if hasLore(attacker's held item, "firststrike") is true:
		health of victim is equal to the maximum health of victim:
			set the damage to the damage * 1.5
			set {_ndamage} to the damage
			scriptDebugBroadcastType("loredamage", "%{_odamage}%: Firststrike Damage Bonus x1.5 -> %{_ndamage}%")
			set {_odamage} to the damage
	if hasLore(attacker's held item, "siphon") is true:
		if victim is a player:
			subMana(victim, 25, false)
		addMana(attacker, 15)
	if hasEffect(attacker, "infected") is true:
		chance of 15%:
			applyEffect(victim, "infected", 1 hour)

	
	
	if attacker is set:
		set {_critchance} to calculateCritical(attacker, victim)
		set {_opchance} to calculateOverpower(attacker, victim)

		chance of {_critchance}:
			set the damage to the damage * 1.5
			#send "&6You landed a critical hit!" to the attacker
			set {_ndamage} to the damage
			scriptDebugBroadcastType("critdamage", "%{_odamage}%: Critical Hit Damage Bonus x1.5 -> %{_ndamage}%")
			set {_odamage} to the damage
			hasClass(attacker, "rogue") is true:
				applyEffect(attacker, "dark shroud", 1 minute)
				if {-rpgSkript::%attacker%::darkshroud} is not set:
					set {-rpgSkript::%attacker%::darkshroud} to 0
				set {-rpgSkript::%attacker%::darkshroud} to {-rpgSkript::%attacker%::darkshroud} + 1
		chance of {_opchance}:
			set the damage to the damage * 1.5
			set {_ndamage} to the damage
			scriptDebugBroadcastType("opdamage", "%{_odamage}%: Overpowered Attack Damage Bonus x1.5 -> %{_ndamage}%")
			set {_odamage} to the damage
		#send "&6You landed an overpowered attack!" to the attacker

	{commandSkript::%victim%::isTrainingDummy} is true:
		send "&6The damage you dealt to the Training Dummy was increased to %{_ndamage}%!" to the attacker
		set the damage to 0

	victim is a player:
		setMaxHealth(the victim)

		if isWearingMediumOrLess(victim) is false:
			set the damage to the damage * 0.5
		else if isWearingLightOrLess(victim) is false:
			set the damage to the damage * 0.7
		else if isWearingNothing(victim) is false:
			set the damage to the damage * 0.9
			

		hasClass(victim, "nethermancer") is true:
			if at least one of:
				damage cause is lava
				damage cause is fire
				damage cause is burn
				damage cause is hot floor
			then:
				regenHeat(victim, 30)
				cancel the event
				stop
			if attacker is set:
				event-projectile is not set:
					if {rpgSkript::heat::%victim%} is greater than 500:
						applyEffect(attacker, "firestorm", 10 seconds)
					else:
						ignite the attacker
			if event-projectile is set:
				chance of 50%:
					delete the projectile
					cancel the event
					stop
			if 1 - (0.6 * (1 - ( {rpgSkript::heat::%victim%} / 1000 ) ) ) is less than 0:
				set {_netherdmgreduction} to 0
			else:
				set {_netherdmgreduction} to 1 - (0.6 * (1 - ( {rpgSkript::heat::%victim%} / 1000 ) ) )
			set the damage to the damage * {_netherdmgreduction}
			set {_ndamage} to the damage
			scriptDebugBroadcastType("nethermancerdamage", "%{_odamage}%: Nethermancer Damage Reduction x%{_netherdmgreduction}% -> %{_ndamage}%")
			set {_odamage} to the damage
		hasClass(victim, "monk") is true:
			canUseMonkAbilities(victim) is true
			damage cause is fall:
				set the damage to the damage * 0.5
			if {-rpgSkript::%victim%::consecutiveVictim} is not set:
				set {-rpgSkript::%victim%::consecutiveVictim} to 0
			if attacker is set:
				if the damage is greater than 0:
					set {-rpgSkript::%victim%::consecutiveVictim} to {-rpgSkript::%victim%::consecutiveVictim} + 1
					if {-rpgSkript::%victim%::consecutiveVictim} is 5:
						set {-rpgSkript::%victim%::consecutiveVictim} to 0
						damage attacker by damage * 0.8
						set the damage to 0
						send "&eParried!" to victim
						if health of victim is equal to maximum health of victim:
							apply absorption 2 without particles to the victim for 10 seconds replacing the existing effect
						else:
							heal(victim, 2)
		hasClass(victim, "herobrine") is true:
			set the damage to the damage * 0.3
			set {_ndamage} to the damage
			scriptDebugBroadcastType("herobrinedamage", "%{_odamage}%: Herobrine Damage Reduction x0.3 -> %{_ndamage}%")
			set {_odamage} to the damage
			damage cause is fall:
				cancel the event
			damage cause is burn:
				cancel the event
			damage cause is lava:
				cancel the event
			damage cause is hot floor:
				cancel the event
			damage cause is drowning:
				cancel the event
			damage cause is freeze:
				cancel the event
		hasClass(victim, "warrior") is true:
			set the damage to the damage * 0.65
			set {_ndamage} to the damage
			scriptDebugBroadcastType("warriordamage", "%{_odamage}%: Warrior Damage Reduction x0.65 -> %{_ndamage}%")
			set {_odamage} to the damage
		hasClass(victim, "rogue") is true:
			canUseRogueAbilities(victim) is true
			damage cause is fall:
				set the damage to the damage * 0.3
				set {_ndamage} to the damage
				scriptDebugBroadcastType("roguedamage", "%{_odamage}%: Rogue Fall Damage Reduction x0.3 -> %{_ndamage}%")
				set {_odamage} to the damage
			chance of 45%:
				set the damage to 0
				set {_ndamage} to the damage
				scriptDebugBroadcastType("roguedamage", "%{_odamage}%: Rogue Damage Negation =0 -> %{_ndamage}%")
				set {_odamage} to the damage
				play sound "entity.player.attack.nodamage" at victim
				send action bar "&2~ ~ DODGE ~ ~" to victim
		hasClass(victim, "paladin") is true:
			isMonster(attacker) is true:
				set the damage to the damage * 0.6
				set {_ndamage} to the damage
				scriptDebugBroadcastType("paladindamage", "%{_odamage}%: Paladin Monster Damage Reduction x0.6 -> %{_ndamage}%")
				set {_odamage} to the damage
			damage cause is poison:
				cancel the event
			damage cause is wither potion effect:
				cancel the event
		hasClass(victim, "barbarian") is true:
			if event-projectile is set:
				set the damage to the damage * 1.3
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Projectile Weakness x1.3 -> %{_ndamage}%")
				set {_odamage} to the damage
			canUseBarbarianAbilities(victim) is true:
				set {_damagered} to 1 - ( {rpgSkript::%victim%::barbenemies} * 0.05 )
				if {_damagered} is less than 0.5:
					set {_damagered} to 0.5
				set the damage to the damage * {_damagered}
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Surrounded Damage Reduction x%{_damagered}% -> %{_ndamage}%")
				set {_odamage} to the damage
				set {_damagered} to 0.2 + ( health of victim / maximum health of victim )
				if {_damagered} is greater than 1:
					set {_damagered} to 1
				set the damage to the damage * {_damagered}
				set {_ndamage} to the damage
				scriptDebugBroadcastType("barbariandamage", "%{_odamage}%: Barbarian Health Damage Reduction x%{_damagered}% -> %{_ndamage}%")
				set {_odamage} to the damage
				if hasResearch(victim, "Thorns") is true:
					chance of 35%:
						damage attacker by 0.5 + ( 1 - (health of attacker / maximum health of attacker ) )
				attacker is set:
					chance of 30%:
						rageTrigger(victim)
		hasClass(victim, "endwarden") is true:
			canUseEndwardenAbilities(victim) is true:
				damage cause is fall:
					health of victim is less than damage:
						set the damage to the damage / 2 
						set {_ndamage} to the damage
						scriptDebugBroadcastType("endwardendamage", "%{_odamage}%: Endwarden Teleport Damage Reduction x0.5 -> %{_ndamage}%")
						set {_odamage} to the damage
						applyEffect(victim, "phased", 5 seconds)
				health of victim is less than damage:
					chance of 30:
						set the damage to the damage / 2 
						set {_ndamage} to the damage
						scriptDebugBroadcastType("endwardendamage", "%{_odamage}%: Endwarden Teleport Damage Reduction x0.5 -> %{_ndamage}%")
						set {_odamage} to the damage		
						applyEffect(victim, "phased", 5 seconds)
						
		hasClass(victim, "druid") is true:
			canUseDruidAbilities(victim) is true:
				if {rpgSkript::%victim%::spidershape} is true:
					damage cause is poison:
						cancel the event
						stop
				else if {rpgSkript::%victim%::batshape} is true:
					set the damage to the damage * 1.25
					set {_ndamage} to the damage
					scriptDebugBroadcastType("druiddamage", "%{_odamage}%: Druid Bat Weakness x1.25 -> %{_ndamage}%")
					set {_odamage} to the damage
					damage cause is fall:
						set the damage to 0

		hasClass(victim, "nethermancer") is true:
			if the damage is greater than 1:
				regenHeat(victim, ceiling(the damage * 0.5))
			else:
				regenHeat(victim, 1)

		if the damage is greater than 0:
			loop all players in radius 15 around victim:
				if hasImbue(loop-player, "guardian") is true:
					loop-player is not victim
					set health of loop-player to health of loop-player - the damage * 0.1
					set the damage to the damage * 0.75

		# Needs to be very last
		hasEffect(victim, "soulbond") is true:
			{-rpgSkript::%victim%::soulbondplayer} is alive:
				set the damage to the damage * 0.5
				set health of {-rpgSkript::%victim%::soulbondplayer} to health of {-rpgSkript::%victim%::soulbondplayer} - the damage
				

	hasImbue(victim, "mana shield") is true:
		subMana(victim, the damage * 7.0, false) is true
		set {_reduction} to 1 - (0.15 * countImbue(victim, "mana shield") )
		if {_reduction} is less than 0.5:
			set {_reduction} to 0.5
		set the damage to the damage * {_reduction}
		set {_ndamage} to the damage
		scriptDebugBroadcastType("imbuedamage", "%{_odamage}%: Mana Shield Reduction x%{_reduction}% -> %{_ndamage}%")
		set {_odamage} to the damage

	hasImbue(victim, "undying") is true:
		set {_damagered} to (0.3 - (countImbue(victim, "undying") * 0.075)) + ( health of victim / maximum health of victim )
		if {_damagered} is greater than 1:
			set {_damagered} to 1
		set the damage to the damage * {_damagered}

	hasImbue(victim, "detonation") is true:
		chance of 30%:
			loop all entities in radius 5 around victim:
				isMonster(loop-entity) is true
				set {_randmg} to a random number between 2.5 and 10
				damage loop-entity by {_randmg}

	hasImbue(victim, "Razorplate") is true:
		event-projectile is not set
		damage attacker by 5 * countImbue(victim, "Razorplate")

	hasImbue(victim, "guardian") is true:
		set the damage to the damage * 0.75

	hasImbue(victim, "flame shield") is true:
		set {_loc} to the victim's location
		set {_loc} to the location 1 meter above {_loc}
		show mob spawner flames at {_loc}
		event-projectile is set:
			delete event-projectile
			cancel the event
			stop
		if damage cause is burn:
			set the damage to the damage * 0.75
			set {_ndamage} to the damage
			scriptDebugBroadcastType("imbuedamage", "%{_odamage}%: Flame Shield Fire Reduction x0.75 -> %{_ndamage}%")
			set {_odamage} to the damage
		else:
			set the damage to the damage * 0.95
			set {_ndamage} to the damage
			scriptDebugBroadcastType("imbuedamage", "%{_odamage}%: Flame Shield Reduction x0.95 -> %{_ndamage}%")
			set {_odamage} to the damage
		ignite the attacker for 2 seconds

	hasImbue(victim, "frost shield") is true:
		set {_loc} to the victim's location
		set {_loc} to the location 1 meter above {_loc}
		show splash at {_loc}
		event-projectile is not set:
			if damage cause is freeze:
				set the damage to the damage * 0.75
				set {_ndamage} to the damage
				scriptDebugBroadcastType("imbuedamage", "%{_odamage}%: Frost Shield Freeze Reduction x0.75 -> %{_ndamage}%")
				set {_odamage} to the damage
			else:
				set the damage to the damage * 0.95
				set {_ndamage} to the damage
				scriptDebugBroadcastType("imbuedamage", "%{_odamage}%: Frost Shield Reduction x0.95 -> %{_ndamage}%")
				set {_odamage} to the damage

	hasImbue(victim, "iron will") is true:
		if at least one of:
			damage cause is burn
			damage cause is freeze
			damage cause is poison
			damage cause is wither potion effect
		then:
			set {_reduction} to 1 - (0.15 * countImbue(victim, "iron will") )
			set the damage to the damage * {_reduction}
			set {_ndamage} to the damage
			scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Iron Will DoT Reduction x%{_reduction}% -> %{_ndamage}%")
			set {_odamage} to the damage

	hasImbue(victim, "reinforced") is true:
		set {_reduction} to 1 - (0.05 * countImbue(victim, "reinforced") )
		set the damage to the damage * {_reduction}
		set {_ndamage} to the damage
		scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Reinforced Reduction x%{_reduction}% -> %{_ndamage}%")
		set {_odamage} to the damage		

	hasEffect(victim, "dark shroud") is true:
		if {-rpgSkript::%victim%::darkshroud} is greater than 0:
			set the damage to the damage * 0.75
			set {_ndamage} to the damage
			scriptDebugBroadcastType("effectdamage", "%{_odamage}%: Dark Shroud Damage Reduction x0.9 -> %{_ndamage}%")
			set {_odamage} to the damage
			play sound "entity.ender_eye.death" with pitch 0.5 at the victim
			loop all entities in radius 3 around victim:
				loop-entity is not victim
				hasClass(loop-entity, "endwarden") is false
				applyEffect(loop-entity, "void", 10 seconds)
				damage loop-entity by 1
				wait 1 tick
			set {-rpgSkript::%victim%::darkshroud} to {-rpgSkript::%victim%::darkshroud} - 1

	if the damage is greater than 0:
		applyEffect(victim, "recentcombat", 2 seconds)
		applyEffect(attacker, "recentcombat", 2 seconds)
	
on target:

	{-evilSkript::%event-entity%::summoner} is true:
		{rpgSkript::%event-entity%::lastSummon} is not set:
			set {rpgSkript::%event-entity%::lastSummon} to 30 minutes ago
		difference between {rpgSkript::%event-entity%::lastSummon} and now is less than 15 seconds:
			stop
		set {rpgSkript::%event-entity%::lastSummon} to now
		loop {-evilSkript::%event-entity%::summoncount} times:
			event-entity is a skeleton:
				spawn 1 skeleton at event-entity
				{-evilSkript::%event-entity%::HeadHunter} is true:
					spawn 1 zombie at event-entity
			event-entity is a zombie:
				spawn 1 zombie at event-entity
			event-entity is a evoker:
				set {_chance} to a random number between 1 and 100
				if {_chance} is greater than 90:
					spawn 1 ravager at event-entity
				else if {_chance} is greater than 75:
					spawn 1 vindicator at event-entity
				else if {_chance} is greater than 60:
					spawn 1 evoker at event-entity
				else if {_chance} is greater than 45:
					spawn 1 witch at event-entity
				else if {_chance} is greater than 25:
					spawn 2 pillager at event-entity
				else:
					spawn 3 vex at event-entity
			event-entity is a spider:
				spawn 1 cave spider at event-entity:
					set movement speed attribute of the spider to 3 * movement speed attribute of the cave spider
					set attack damage attribute of the spider to 0.75 * attack damage attribute of the cave spider
					set maximum health of the cave spider to 2.5			
			event-entity is a zombie:
				spawn 1 zombie at event-entity:
					if {-evilSkript::%event-entity%::Rotwalker} is true:
						set movement speed attribute of the zombie to 2 * movement speed attribute of the zombie
						set attack damage attribute of the spider to 1.5 * attack damage attribute of the zombie
						set maximum health of the zombie to 5						
						applyEffect(the zombie, "radiated", 1 hour)
			event-entity is a creeper:
				spawn 1 creeper at event-entity:
					makeLunatic(the creeper)

	{-commandSkript::%target%::isTrainingDummy} is true:
		cancel the event
				
	isMinion(event-entity) is true:
		target is a player:
			cancel the event
			stop
		getSummoner(uuid of event-entity) is target:
			cancel the event
			stop
		isMinion(target) is true:
			hasSameSummoner(event-entity, target) is true:
				cancel the event
				stop
		event-entity is a pillager:
			{-rpgSkript::%event-entity%::raidMage} is true:
				cancel the event
				stop

	target is a player
	hasClass(target, "herobrine") is true:
		cancel the event
		stop
	hasClass(target, "rogue") is true:
		canUseRogueAbilities(target) is true
		distance between event-entity and target is greater than 10:
			cancel the event
			stop
		chance of 80%:
			cancel the event
			stop
	hasImbue(target, "spidersilk") is true:
		if target is sprinting:
			distance between event-entity and target is greater than 12:
				cancel the event
				stop
		else if target is sneaking:
			distance between event-entity and target is greater than 2.5:
				cancel the event
				stop
		else:
			distance between event-entity and target is greater than 7.5:
				cancel the event
				stop
	hasClass(target, "paladin") is true:
		isMonster(event-entity) is true:
			applyEffect(event-entity, "hallowed", 8 seconds)
	hasClass(target, "druid") is true:
		if {rpgSkript::%target%::batshape} is true:
			chance of 80%:
				cancel the event
				stop
		if {rpgSkript::%target%::wolfshape} is true:
			chance of 60%:
				cancel the event
				stop
		else if {rpgSkript::%target%::spidershape} is true:
			chance of 40%:
				cancel the event
				stop
	hasEffect(target, "invisible") is true:
		reset target of event-entity
		cancel the event

on item damage:
	event-item is a shield:
		chance of 50%:
			cancel the event
			stop
	hasLore(event-item, "unbreakable") is true:
		cancel the event
		stop
	hasClass(player, "herobrine") is true:
		cancel the event
		stop
	hasClass(player, "paladin") is true:
		subMana(player, 2, false) is true:
			cancel the event
			stop
	hasClass(player, "warrior") is true:
		chance of 45%:
			cancel the event
			stop
	hasClass(player, "rogue") is true:
		chance of 25%:
			cancel the event
			stop
	hasLore(event-item, "reinforced") is true:
		chance of 50%:
			cancel the event
			stop

function calculateCritical(hit:entity, damaged:entity) :: number:
	set {_crit} to 0.05
	hasClass({_hit}, "rogue") is true:
		set {_crit} to {_crit} + 0.15
	hasClass({_hit}, "monk") is true:
		{_hit}'s held item is air
		set {_crit} to {_crit} + 0.15
	hasClass({_hit}, "warrior") is true:
		set {_crit} to {_crit} + 0.1
	hasClass({_hit}, "barbarian") is true:
		set {_crit} to {_crit} + 0.1
	hasClass({_hit}, "paladin") is true:
		isMonster({_damaged}) is true:
			set {_crit} to {_crit} + 0.5
	hasClass({_hit}, "druid") is true:
		if {rpgSkript::%{_hit}%::spidershape} is true:
			set {_crit} to {_crit} + 0.1
		if {rpgSkript::%{_hit}%::wolfshape} is true:
			set {_crit} to {_crit} + 0.125
	hasClass({_hit}, "herobrine") is true:
		set {_crit} to 1
	hasImbue({_hit}, "bloodied") is true:
		set {_crit} to {_crit} + (1 - (health of {_hit} / maximum health of {_hit}))
	hasImbue({_hit}, "subdue to anger") is true:
		set {_crit} to {_crit} + 0.2
	hasEffect({_damaged}, "Void") is true:
		set {_crit} to {_crit} + 0.1
	hasEffect({_damaged}, "Vulnerable") is true:
		set {_crit} to {_crit} + 0.1
	hasEffect({_hit}, "invisible") is true:
		set {_crit} to {_crit} + 0.05
	hasEffect({_hit}, "inspired") is true:
		set {_crit} to {_crit} + 0.05
	
	return {_crit}

function calculateOverpower(hit:entity, damaged:entity) :: number:
	set {_op} to 0.05
	hasClass({_hit}, "warrior") is true:
		set {_op} to {_op} + 0.1
	hasClass({_hit}, "barbarian") is true:
		set {_op} to {_op} + 0.2
	hasClass({_hit}, "druid") is true:
		if {rpgSkript::%{_hit}%::bearshape} is true:
			set {_op} to {_op} + 0.15
		if {rpgSkript::%{_hit}%::horseshape} is true:
			set {_op} to {_op} + 0.1
	hasClass({_hit}, "herobrine") is true:
		set {_op} to 1
	hasEffect({_damaged}, "Void") is true:
		set {_op} to {_op} + 0.1
	hasEffect({_hit}, "invisible") is true:
		set {_op} to {_op} + 0.05
	hasEffect({_hit}, "rage") is true:
		set {_op} to {_op} + 0.1
	hasEffect({_damaged}, "Vulnerable") is true:
		set {_crit} to {_crit} + 0.1
	hasEffect({_hit}, "inspired") is true:
		set {_crit} to {_crit} + 0.05
	return {_op}
	  

function generateLootHelmet() :: item:
	set {_item} to a leather helmet
	chance of 50%:
		set {_item} to a gold helmet
	chance of 30%:
		set {_item} to a iron helmet
	chance of 10%:
		set {_item} to a diamond helmet
	chance of 5%:
		set {_item} to a netherite helmet

	set {_item} to generateLore({_item})


	
	return {_item}

