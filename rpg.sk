command /fix:
	executable by: players
	trigger:
		if hasClass(player, "artificer") is true:
			subMana(player, 100) is false:
				send "&cNot enough Mana to fix this item" to the player
				stop
			send "&bYou successfully repair your held item!" to the player
			repair player's held item
		else:
			send "&cYou are not an Artificer" to the player		

command /artifice <text>:
	executable by: players
	trigger:
		if at least one of:
			hasClass(player, "artificer") is true
			arg 1 is "reinforced"
		then:
			player's held item is not air
			set {_imbue} to arg 1
			set {_item} to player's held item
			canArtifice({_item}) is false:
				send "&cThis item has been artificed the max amount of times!" to the player
				stop
			if arg 1 is not "reinforced":
				subMana(player, 100) is false:
					send "&cYou do not have that amount of mana available" to the player
					stop

			if isArmorArtificeImbue({_imbue}) is true:
				if at least one of:
					player's held item is any armor
					player's held item is a shield
				then:
					if takeItems(player, (getItemCostForImbue({_imbue}, {_item}))) is true:
						set player's held item to addImbue({_item}, "&b%{_imbue}%")
					else:
						send "&cYou do not have the required items to add that imbuement!" to player
				else:
					send "&cWrong item for that Artifice! %{_imbue}% must goes on Armor!" to the player
			else if isWeaponArtificeImbue({_imbue}) is true:
				if at least one of:
					player's held item is a sword
					player's held item is an axe
					player's held item is a bow
					player's held item is a crossbow
					player's held item is a trident
				then:
					if takeItems(player, getItemCostForImbue({_imbue}, {_item})) is true:
						set player's held item to addImbue({_item}, "&b%{_imbue}%")
					else:
						send "&cYou do not have the required items to add that imbuement!" to player
				else:
					send "&cWrong item for that Artifice! %{_imbue}% must goes on Weapons!" to the player
			else if isToolArtificeImbue({_imbue}) is true:
				if at least one of:
					player's held item is a pickaxe
					player's held item is an axe
					player's held item is a shovel
					player's held item is a hoe
					player's held item are shears
				then:
					if takeItems(player, getItemCostForImbue({_imbue}, {_item})) is true:
						set player's held item to addImbue({_item}, "&b%{_imbue}%")
					else:
						send "&cYou do not have the required items to add that imbuement!" to player
				else:
					send "&cWrong item for that Artifice! %{_imbue}% must goes on Tools!" to the player
			else if player's held item is gunpowder:
				if at least one of:
					{_imbue} is "lesser mine"
					{_imbue} is "greater mine"
					{_imbue} is "auto mine"
					{_imbue} is "poison mine"
				then:
					if takeItems(player, getItemCostForImbue({_imbue}, {_item})) is true:
						set player's held item to addImbue({_item}, "&b%{_imbue}%")				
				else:
					send "&cWrong item for that Artifice!" to the player			
			else:
				send "&cNot a Valid Artifice!" to the player
				stop
			send "&bYou successfully artifice your held item!" to the player
		else:
			send "&cYou are not an Artificer" to the player		

command /worktable:
	executable by: players
	trigger:
		if hasClass(player, "artificer") is true:
			show crafting table to player
		else:
			send "&cNot an Artificer" to the player

command /activate <text>:
	executable by: players
	trigger:
		if hasClass(player, "artificer") is true:
			if arg 1 is "Mine":
				if {-rpgSkript::%player%::mineLocation} is set:
					if {-rpgSkript::%player%::minePower} is "greater":			
						detonate(block at {-rpgSkript::%player%::mineLocation}, 4.99)
						loop all entities in radius 5 around {-rpgSkript::%player%::mineLocation}:
							loop-entity is not a dropped item
							set {_vec} to vector between block at {-rpgSkript::%player%::mineLocation} and loop-entity
							set y component of {_vec} to 0
							set {_vec} to normalized {_vec}
							push loop-entity {_vec} with force 1.4
							push loop-entity upwards with force 0.9
							damage loop-entity by 8.0
						create a fake explosion at {-rpgSkript::%player%::mineLocation}

					else if {-rpgSkript::%player%::minePower} is "lesser":			
						detonate(block at {-rpgSkript::%player%::mineLocation}, 2.99)
						loop all entities in radius 3 around {-rpgSkript::%player%::mineLocation}:
							loop-entity is not a dropped item
							set {_vec} to vector between block at {-rpgSkript::%player%::mineLocation} and loop-entity
							set y component of {_vec} to 0
							set {_vec} to normalized {_vec}
							push loop-entity {_vec} with force 1.2
							push loop-entity upwards with force 0.7
							damage loop-entity by 5.0
						create a fake explosion at {-rpgSkript::%player%::mineLocation}

					if {-rpgSkript::%player%::minePoison} is true:
						createWorldEffect({-rpgSkript::%player%::mineLocation}, "poison_gas", 20 seconds, player)	

					send "&6Mine Detonated!" to the player
					set {-_rpgSkript::%player%::minePoison} to false
					set {-_rpgSkript::%player%::mineAuto} to false
					clear {-rpgSkript::%player%::mineLocation}
					clear {-rpgSkript::%player%::minePower}
			else:
				send "&cNo Tool to Activate" to the player	
		else:
			send "&cNot an Artificer" to the player

on right click with gunpowder:
	if hasClass(event-player, "artificer") is true:
		if at least one of:
			hasLore(event-player's held item, "lesser mine") is true
			hasLore(event-player's held item, "greater mine") is true
			hasLore(event-player's held item, "poison mine") is true
		then:
			set {-rpgSkript::%event-player%::mineAuto} to "false"
			set {-rpgSkript::%event-player%::minePoison} to "false"
			set {-rpgSkript::%event-player%::mineLocation} to location of event-block
			if hasLore(event-player's held item, "greater mine") is true:
				set {-rpgSkript::%event-player%::minePower} to "greater"
			else if hasLore(event-player's held item, "lesser mine") is true:
				set {-rpgSkript::%event-player%::minePower} to "lesser"
			if hasLore(event-player's held item, "poison mine") is true:
				set {-rpgSkript::%event-player%::minePoison} to true
			if hasLore(event-player's held item, "auto mine") is true:
				set {-rpgSkript::%event-player%::mineAuto} to true
			send "&6Mine Set!" to the event-player
			

function isArmorArtificeImbue(imbue: text) :: boolean:
	if at least one of:
		{_imbue} is "golem"
		{_imbue} is "mana shield"
		{_imbue} is "flame shield"
		{_imbue} is "frost shield"
		{_imbue} is "iron will"
		{_imbue} is "speed"
		{_imbue} is "reinforced"
		{_imbue} is "enlighten"
	then:
		return true
	return false

function isWeaponArtificeImbue(imbue: text) :: boolean:
	if at least one of:
		{_imbue} is "vampiric"
		{_imbue} is "hallowed"
		{_imbue} is "bleeding"
		{_imbue} is "shocking"
		{_imbue} is "mana leak"
		{_imbue} is "repulsor"
		{_imbue} is "firststrike"
		{_imbue} is "detonate"
		{_imbue} is "enlighten"
		{_imbue} is "reinforced"
	then:
		return true
	return false

function isToolArtificeImbue(imbue: text) :: boolean:
	if at least one of:
		{_imbue} is "excavation"
		{_imbue} is "enlighten"
		{_imbue} is "reinforced"
	then:
		return true
	return false

function canArtifice(item: item) :: boolean:
	if lastLoreLine({_item}) > 4:
		return false
	return true

function getMaxArtificerMana(player: player) :: number:
	set {_anvil} to false
	set {_crafting} to false
	set {_blast} to false
	set {_furnace} to false
	set {_brewing} to false
	set {_enchanting} to false
	set {_grindstone} to false
	set {_smithing} to false
	set {_stonecutter} to false
	set {_chest} to false
	set {_fletching} to false
	set {_cartography} to false
	set {_ender} to false
	set {_cauldron} to false

	set {_newMax} to 0

	set {_loc} to location of {_player}
	set {_loc} to the location 1 meter above {_loc}

	loop all blocks in radius 4 around {_loc}:
		if loop-block is an anvil:
			if {_anvil} is false:
				set {_newMax} to {_newMax} + 40
				set {_anvil} to true
		if loop-block is a crafting table:
			if {_crafting} is false:
				set {_newMax} to {_newMax} + 10
				set {_crafting} to true
		if loop-block is an enchanting table:
			if {_enchanting} is false:
				set {_newMax} to {_newMax} + 40
				set {_enchanting} to true
		if loop-block is a smithing table:
			if {_smithing} is false:
				set {_newMax} to {_newMax} + 50
				set {_smithing} to true
		if loop-block is a furnace:
			if {_furnace} is false:
				set {_newMax} to {_newMax} + 25
				set {_furnace} to true
		if loop-block is an blast furnace:
			if {_blast} is false:
				set {_newMax} to {_newMax} + 35
				set {_blast} to true
		if loop-block is a grindstone:
			if {_grindstone} is false:
				set {_newMax} to {_newMax} + 20
				set {_grindstone} to true
		if loop-block is a stonecutter:
			if {_stonecutter} is false:
				set {_newMax} to {_newMax} + 35
				set {_stonecutter} to true
		if loop-block is a chest:
			if {_chest} is false:
				set {_newMax} to {_newMax} + 10
				set {_chest} to true
		if loop-block is a fletching table:
			if {_fletching} is false:
				set {_newMax} to {_newMax} + 20
				set {_fletching} to true
		if loop-block is a cartography table:
			if {_cartography} is false:
				set {_newMax} to {_newMax} + 15
				set {_cartography} to true
		if loop-block is an ender chest:
			if {_ender} is false:
				set {_newMax} to {_newMax} + 30
				set {_ender} to true
		if loop-block is a cauldron:
			if {_cauldron} is false:
				set {_newMax} to {_newMax} + 15
				set {_cauldron} to true

	return {_newMax}

on mine of (sand or gravel or dirt or grass block):
	hasLore(event-player's held item, "excavation") is true:
		loop all blocks in radius 1.99 around event-block:
			if at least one of:
				loop-block is sand
				loop-block is gravel
				loop-block is dirt
				loop-block is grass block
			then:
				break loop-block naturally

on projectile hit:
	hasLore(shooter's held item, "Repulsor") is true:
		loop all entities in radius 10 around event-projectile:
			set {_vec} to vector between loop-entity and event-projectile
			set y component of {_vec} to 0
			set {_vec} to normalized {_vec}
			push loop-entity {_vec} with force 1.5
			push loop-entity upwards with force 0.5
	hasLore(shooter's held item, "Detonate") is true:
		detonate(block at event-projectile, 2.5)
		loop all entities in radius 5 around event-projectile:
			loop-entity is not a dropped item
			damage loop-entity by 4.5
		create a fake explosion at event-projectile
	hasLore(shooter's held item, "electric smoke") is true:
		createWorldEffect(location of event-projectile, "electric_smoke", 20 seconds, shooter)

function detonate(block: block, range: number):
	loop all blocks in radius {_range} around {_block}:
		if at least one of:
			loop-block is gravel
			loop-block is dirt
			loop-block is grass block
			loop-block is sand
			loop-block is any leaves
		then:
			break loop-block naturally

# Bard

# Nethermancer

function inventorySmelt(player: player):
	hasClass({_player}, "nethermancer") is true
	if {rpgSkript::heat::%{_player}%} is greater than 249:
		if {_player}'s off hand item is raw porkchop:
			hasItems({_player}, 1 raw porkchop) is true
			chance of 50%:
				takeItems({_player}, 1 raw porkchop)
				give 1 cooked porkchop to {_player}
		else if {_player}'s off hand item is raw cod:
			hasItems({_player}, 1 raw cod) is true
			chance of 50%:
				takeItems({_player}, 1 raw cod)
				give 1 cooked cod to {_player}
		else if {_player}'s off hand item is raw salmon:
			hasItems({_player}, 1 raw salmon) is true
			chance of 50%:
				takeItems({_player}, 1 raw salmon)
				give 1 cooked salmon to {_player}
		else if {_player}'s off hand item is raw beef:
			hasItems({_player}, 1 raw beef) is true
			chance of 50%:
				takeItems({_player}, 1 raw beef)
				give 1 cooked beef to {_player}
		else if {_player}'s off hand item is potato:
			hasItems({_player}, 1 potato) is true
			chance of 50%:
				takeItems({_player}, 1 potato)
				give 1 baked potato to {_player}
		else if {_player}'s off hand item is raw chicken:
			hasItems({_player}, 1 raw chicken) is true
			chance of 50%:
				takeItems({_player}, 1 raw chicken)
				give 1 cooked chicken to {_player}
		else if {_player}'s off hand item is raw rabbit:
			hasItems({_player}, 1 raw rabbit) is true
			chance of 50%:
				takeItems({_player}, 1 raw rabbit)
				give 1 cooked rabbit to {_player}
		else if {_player}'s off hand item is raw mutton:
			hasItems({_player}, 1 raw mutton) is true
			chance of 50%:
				takeItems({_player}, 1 raw mutton)
				give 1 cooked mutton to {_player}
	if {rpgSkript::heat::%{_player}%} is greater than 499:
		if {_player}'s off hand item is cobblestone:
			hasItems({_player}, 1 cobblestone) is true
			chance of 50%:
				takeItems({_player}, 1 cobblestone)
				give 1 stone to {_player} 
	if {rpgSkript::heat::%{_player}%} is greater than 499:
		if {_player}'s off hand item is sand:
			hasItems({_player}, 1 sand) is true
			chance of 50%:
				takeItems({_player}, 1 sand)
				give 1 glass to {_player} 
	if {rpgSkript::heat::%{_player}%} is greater than 749:
		if {_player}'s off hand item is raw iron:
			hasItems({_player}, 1 raw iron) is true
			chance of 50%:
				takeItems({_player}, 1 raw iron)
				give 1 iron ingot to {_player}
		else if {_player}'s off hand item is raw gold:
			hasItems({_player}, 1 raw gold) is true
			chance of 50%:
				takeItems({_player}, 1 raw gold)
				give 1 gold ingot to {_player}
		else if {_player}'s off hand item is raw copper:
			hasItems({_player}, 1 raw copper) is true
			chance of 50%:
				takeItems({_player}, 1 raw copper)
				give 1 copper ingot to {_player}

function regenHeat(player: player, amount: number):
	hasClass({_player}, "nethermancer") is true
	set {rpgSkript::heat::%{_player}%} to {rpgSkript::heat::%{_player}%} + {_amount}
	if {rpgSkript::heat::%{_player}%} is greater than 1000:
		set {rpgSkript::heat::%{_player}%} to 1000
	if {rpgSkript::heat::%{_player}%} is less than 0:
		set {rpgSkript::heat::%{_player}%} to 0
	scriptDebugBroadcastType("heat", "%{_player}%'s heat levels increase by %{_amount}% to %{rpgSkript::heat::%{_player}%}%")
on left click with lava bucket:
	hasClass(event-player, "nethermancer") is true:
		remove event-item from event-player's inventory
		give bucket to event-player
		apply saturation 2 without particles to event-player for 10 minutes replacing the existing effect
		applyEffect(event-player, "regen", 10 minutes)	
		regenHeat(event-player, 500)
		send "&4You drink some lava for food and heat." to event-player

on left click with water bucket:
	hasClass(event-player, "nethermancer") is true:
		remove event-item from event-player's inventory
		give bucket to event-player
		apply weakness 1 without particles to event-player for 1 minute replacing the existing effect	
		regenHeat(event-player, -100)
		send "&4You drink some water to cool down." to event-player

