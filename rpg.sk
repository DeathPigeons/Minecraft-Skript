command /wizardresearch:
	executable by: players
	trigger:
		hasClass(player, "wizard") is false:
			send "&dYou are not a wizard!"
			exit
		set {_menu} to a new chest inventory with 6 rows named "&dWizard Research"
		
		populateWizardResearchMenu(player, {_menu})
		
		open {_menu} to player

function populateWizardResearchMenu(player: player, menu: inventory):
	set {_item} to red wool named "&7Constant Study"
	if hasResearch({_player}, "power") is true:
		set {_item} to lime wool named "&eConstant Study"
	set line 1 of {_item}'s lore to "&6Gain 3 experience every 2 seconds"
	set slot 31 of {_menu} to {_item}

on inventory click:
	event-inventory is not event-player's inventory
	name of event-inventory is "&dWizard Research"
	cancel event
	
	if index of event-slot is 31:
		if hasResearch(player, "power") is true:
			deleteResearch(player, "power")
		else:
			addResearch(player, "power")

	populateWizardResearchMenu(player, event-inventory)

on right click with lapis lazuli:
	hasClass(player, "wizard") is true
	if subMana(command executor, 60) is false:
		send "&cYou do not have enough Mana to cast the cryoball spell!" to command executor
		stop
		
	set {_c} to 1
	while {_x} is not set:
		if {-rpgSkript::cryoballs::%{_c}%} is not set:
			set {_x} to {_c}
			set {-rpgSkript::cryoballs::%{_x}%} to "cryoball"
		else:
			set {_c} to {_c} + 1
			
	set {_loc} to the command executor's location
	set {_loc} to the location 1.6 meters above {_loc}
	
	set {_v} to vector from yaw (yaw of command executor) and pitch (pitch of command executor)
	set {_v} to normalized {_v}
	set the vector length of {_v} to 2
	
	set {_first} to {_v}
	set vector length of {_first} to 4
	
	set {_loc} to ( {_loc} ~ {_first} )
	
	set {-rpgSkript::cryoballs::%{_x}%::loc} to {_loc}
	set {-rpgSkript::cryoballs::%{_x}%::v} to {_v}
	set {-rpgSkript::cryoballs::%{_x}%::time} to now
	set {-rpgSkript::cryoballs::%{_x}%::caster} to player
	set {-rpgSkript::cryoballs::%{_x}%} to 1
	play sound "item.bucket.empty" with pitch 0.7 at command executor
	send "&dYou release a freezing orb of water!" to command executor



# Necromancer

on right click with banner:
	lastLoreLine(event-item) is greater than 1:
		cancel the event

function isMinion(entity: entity) :: boolean:
	{-rpgSkript::minions::%uuid of {_entity}%} is set:
		return true
	return false

function getByUUID(uuid: text) :: entity:
    set {_cacheResult} to {-rpgSkript::cache::entityByUUID::%{_uuid}%::entity}
    {_cacheResult} is set:
        {_cacheResult} is alive
        return {_cacheResult}
    loop all living entities:
        uuid of loop-entity contains {_uuid}:
            # This gets rid of a warning saying that you can't save entities.
            # The cache is cleared on script unload. It doesn't matter.
            set {_entity} to loop-entity
            set {-rpgSkript::cache::entityByUUID::%{_uuid}%::entity} to {_entity}
            return loop-entity

every 2 seconds:

	set {_start} to now

	loop {-rpgSkript::minions::*}:
	
		set {_uuid} to loop-index
		set {_entity} to getByUUID({_uuid})
		{_entity} is not set:
			deleteMinion({_uuid})
			continue loop
			
		set {_summoner} to {-rpgSkript::minions::%{_uuid}%::summoner}
		{_summoner} is not online:
			killMinion({_uuid})
			continue loop

		target of {_entity} is not set:
			loop living entities in radius 10 of {_entity}:
				if isMonster(loop-entity) is true:
					loop-entity is not {_summoner}:
						set target of {_entity} to loop-entity

		distance between {_entity} and {_summoner} is more than 15:
			make {_entity} pathfind towards {_summoner} at speed 1.3
			reset target of {_entity}

		if at least one of:
			distance between {_entity} and {_summoner} is more than 30
			{_entity}'s world is not {_summoner}'s world
		then:
			teleport {_entity} to {_summoner}
			make {_entity} stop pathfinding
			reset target of {_entity}

	set {_end} to now
	set {_seconds} to difference between {_end} and {_start}
	#broadcast "%{_seconds}%"

on death:

	hasImbue(attacker, "radiation") is true:
		chance of 30%:
			apply saturation 1 without particles to the attacker for 2 seconds replacing the existing effect

	hasLore(attacker's held item, "butcher") is true:
		chance of 25%:
			set {_drop} to rotten flesh
			set {_drop} to addImbue({_drop}, "Butcher's Cuts")
			set name of {_drop} to "&4Butcher's Cuts"
			set {_ran} to a random integer between 1 and 3
			loop {_ran} times:
				add {_drop} to the drops

	the victim is not a player
	isMinion(the victim) is true:
		play sound "entity.player.breath" with pitch 1.5 at the victim
		deleteMinion(uuid of the victim)
		clear drops
	else:
		loop players in radius 50 of the victim:
			hasClass(loop-player, "necromancer") is true:
				add 1 experience to the loop-player

	

on explosion prime:
	event-entity is a creeper:
		isMinion(target of event-entity) is true:
			cancel the event

function deleteMinion(uuid: text):
	#broadcast "&7Deleting minion"
	delete {-rpgSkript::minions::%{_uuid}%}
	delete {-rpgSkript::minions::%{_uuid}%::*}

	set {_entity} to getByUUID({_uuid})
	{_entity} is set:
		reset target of {_entity}

function killMinion(uuid: text):
	#broadcast "&7Killing minion"
	kill getByUUID({_uuid})
	deleteMinion({_uuid})

command /raise <text>:
	description: Raise a minion
	executable by: players
	trigger:
		hasClass(player, "necromancer") is true
		if arg 1 is "skeleton":
			if subMana(command executor, 10) is false:
				send "&cYou do not have enough Mana to raise a skeleton!" to command executor
				stop
			send "&dYou raise an undead skeleton!" to command executor
			set {_player} to the player
			spawn 1 skeleton at the player:
				setupMinion(the skeleton, {_player})
		if arg 1 is "warrior":
			if subMana(command executor, 10) is false:
				send "&cYou do not have enough Mana to raise a skeleton!" to command executor
				stop
			send "&dYou raise an undead skeleton!" to command executor
			set {_player} to the player
			spawn 1 skeleton at the player:
				set movement speed attribute of the skeleton to 1.3 * movement speed attribute of the skeleton
				set the skeleton's held item to iron sword
				setupMinion(the skeleton, {_player})

command /ritual <text>:
	executable by: players
	trigger:
		hasClass(player, "necromancer") is true
		if arg 1 is "strengthen":
			takeItems(player, (16 bone and 32 rotten flesh and 4 spider eyes)) is false:
				send "&cYou do not have the required items to increase your mana (16 bone, 32 rotten flesh, 4 spider eyes)!" to player
				stop
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You temporarily increase your mana and lifeforce!" to player
			set {-rpgSkript::%player%::ritualstr} to true
			set {-rpgSkript::%player%::ritualstrcount} to 3600
			scriptDebugBroadcastType("ritual", "%player%: Strengthen Boolean -> %{rpgSkript::%player%::ritualstr}%")
			scriptDebugBroadcastType("ritual", "%player%: Strengthen Count -> %{rpgSkript::%player%::ritualstrcount}%")
		else if arg 1 is "minions":
			takeItems(player, (16 bone and 32 rotten flesh and 4 spider eyes)) is false:
				send "&cYou do not have the required items to empower your minions (16 bone, 32 rotten flesh, 4 spider eyes)!" to player
				stop
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You temporarily increase your minions power!" to player
			set {-rpgSkript::%player%::ritualmin} to true
			set {-rpgSkript::%player%::ritualmincount} to 3600
		else if arg 1 is "corpse":
			takeItems(player, (16 bone and 32 rotten flesh and 4 spider eyes)) is false:
				send "&cYou do not have the required items to grant yourself the 'Corpse Explosion' power (16 bone, 32 rotten flesh, 4 spider eyes)!" to player
				stop
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You become the walking death!" to player
			set {-rpgSkript::%player%::ritualcor} to true
			set {-rpgSkript::%player%::ritualcorcount} to 3600
		else:
			send "&cUnrecognized ability" to player

on right click with bone:
	hasClass(player, "necromancer") is true
	if subMana(command executor, 10) is false:
		send "&cYou do not have enough Mana to raise a skeleton!" to command executor
		stop
	send "&dYou raise an undead skeleton!" to command executor
	set {_player} to the player
	spawn 1 skeleton at the player:
		setupMinion(the skeleton, {_player})

on right click with rotten flesh:
	hasLore(player's held item, "Butcher's Cuts") is false
	hasClass(player, "necromancer") is true
	if subMana(command executor, 10) is false:
		send "&cYou do not have enough Mana to raise a skeleton!" to command executor
		stop
	send "&dYou raise an undead skeleton!" to command executor
	set {_player} to the player
	spawn 1 skeleton at the player:
		set movement speed attribute of the skeleton to 1.3 * movement speed attribute of the skeleton
		set the skeleton's held item to iron sword
		setupMinion(the skeleton, {_player})

on left click with bone:
	if at least one of:
		hasClass(event-player, "necromancer") is true
		hasImbue(event-player, "Raid Leader") is true
		hasImbue(event-player, "Grimoire") is true
	then:
		play sound "entity.player.breath" with pitch 0.7 at player
		loop getMinions(event-player):
			event-player's targeted entity is not set:
				reset target of loop-value
				make loop-value pathfind to event-player's targeted block at speed 1.4
			event-player's targeted entity is set:
				set target of loop-value to event-player's targeted entity

on left click with redstone:
	hasClass(event-player, "necromancer") is true:
		subMana(event-player, 500) is false:
			send "&4Not enough mana to use Blood Surge!" to event-player		
			stop
		if {-rpgSkript::event-player::bloodcount} is not set:
			set {-rpgSkript::event-player::bloodcount} to 0
		set {_monsters} to 0
		play sound "item.trident.riptide_3" with pitch 2 at event-player
		loop all entities in radius 7 around event-player:
			loop-entity is not event-player:
				isMinion(loop-entity) is true:
					getSummoner(uuid of loop-entity) is event-player:
						continue
				damage loop-entity by 2
				set {_monsters} to {_monsters} + 1
				play sound "item.trident.riptide_3" with pitch 2 at loop-entity
				send "&4Your blood has been drained!" to loop-entity
		wait 3 ticks
		if {_monsters} is greater than 0:
			set {-rpgSkript::event-player::bloodcount} to {-rpgSkript::event-player::bloodcount} + 1
		if {-rpgSkript::event-player::bloodcount} is greater than 4:
			set {_damage} to 5 * (1 + ({_monsters}/2) ) * 2
			scriptDebugBroadcastType("necromancerdamage", "Blood Damage Spread out Between %{_monsters}% entities with 5 stacks -> %{_damage}%")
			set {-rpgSkript::event-player::bloodcount} to 0
		else:
			set {_damage} to 5 * (1 + ({_monsters}/2) )
			scriptDebugBroadcastType("necromancerdamage", "Blood Damage Spread out Between %{_monsters}% entities -> %{_damage}%")
		loop all entities in radius 7 around event-player:
			loop-entity is not event-player:
				isMinion(loop-entity) is true:
					getSummoner(uuid of loop-entity) is event-player:
						continue
				damage loop-entity by {_damage}
				play sound "item.trident.riptide_3" with pitch 2 at loop-entity
		heal(event-player, 3 * {_monsters} )

function setupMinion(entity: entity, summoner: player):
	set {-rpgSkript::minions::%uuid of {_entity}%} to 1
	set {-rpgSkript::minions::%uuid of {_entity}%::summoner} to {_summoner}
	set {_entity}'s helmet to leather helmet
	dye {_entity}'s helmet blue
	enchant {_entity}'s helmet with protection 1
	reset target of {_entity}

function hasSameSummoner(entity: entity, entity2: entity) :: boolean:
	{-rpgSkript::minions::%uuid of {_entity}%::summoner} is {-rpgSkript::minions::%uuid of {_entity2}%::summoner}:
		return true
	return false

function getSummoner(uuid: text) :: player:
	{-rpgSkript::minions::%{_uuid}%::summoner} is set:
		return {-rpgSkript::minions::%{_uuid}%::summoner}

function getMinionCount(summoner: player) :: number:
	set {_count} to 0
	loop {-rpgSkript::minions::*}:
		getSummoner(loop-index) is {_summoner}:
			set {_count} to {_count} + 1
	return {_count}

function getMinionUUIDs(summoner: player) :: texts:
	loop {-rpgSkript::minions::*}:
		getSummoner(loop-index) is {_summoner}:
			add loop-index to {_list::*}
	return {_list::*}

function getMinions(summoner: player) :: entities:
	set {_uuids::*} to getMinionUUIDs({_summoner})
	loop {_uuids::*}:
		add getByUUID({_uuids::%loop-index%}) to {_list::*}
	return {_list::*}

function calculateMaxMinions(summoner: player) :: number:
	set {_count} to 0
	hasClass({_summoner}, "necromancer") is true:
		set {_count} to 5
		set {_count} to {_count} + getLevel({_summoner}) / 20
		isWearingLightOrLess({_summoner}) is true:
			set {_count} to {_count} * 2.0
	hasClass({_summoner}, "druid") is true:
		set {_count} to 3
	hasImbue({_summoner}, "Raid Leader") is true:
		set {_count} to {_count} + 5
	hasImbue({_summoner}, "Grimoire") is true:
		set {_count} to {_count} + 10

	return floor({_count})

function cullMinions(summoner: player):
	set {_toRemove} to getMinionCount({_summoner}) - calculateMaxMinions({_summoner})
	loop {-rpgSkript::minions::*}:
		{_toRemove} > 0:
			getSummoner(loop-index) is {_summoner}:
				killMinion(loop-index)
				set {_toRemove} to {_toRemove} - 1



# Cleric



on resurrect attempt:
	entity is a player:
		hasClass(player, "cleric") is true:
			chance of 30%:
				uncancel the event
				send "&6The gods save you from death!" to the player
				stop
			subMana(player, 500) is true:
				uncancel the event
				send "&6You use your divine powers to escape death!" to the player
				stop
			scriptDebugBroadcastType("cleric", "%player% attempts reviving")

on heal:
	event-entity is a player:
		hasClass(event-player, "cleric") is true:
			set the heal amount to the heal amount * 2
		scriptDebugBroadcastType("heal", "%player% heals for %heal amount%")

command /pray <text>:
	executable by: players
	trigger:
		hasClass(player, "cleric") is true
		{rpgSkript::%player%::lastPrayer} is not set:
			set {rpgSkript::%player%::lastPrayer} to 30 minutes ago
		difference between {rpgSkript::%player%::lastPrayer} and now is less than 2 minutes:
			send "&cYou must wait before you can pray again!" to player
			stop
		set {rpgSkript::%player%::lastPrayer} to now
		arg 1 is "food":
			chance of 70%:
				send "&6The gods answer and give you food!" to player
				play sound "entity.elder_guardian.curse" with pitch 2 at player
				giveItem(player, 10 bread)
				stop
		arg 1 is "strength":
			chance of 40%:
				send "&6The gods answer and give you strength!" to player
				play sound "item.trident.thunder" with pitch 2.0 at player
				applyEffect(player, "regen", 60 seconds)
				apply saturation 2 to player for 60 seconds replacing the existing effect
				apply strength 2 to player for 60 seconds replacing the existing effect
				apply haste 2 to player for 60 seconds replacing the existing effect
				apply resistance 2 to player for 60 seconds replacing the existing effect
				stop
		scriptDebugBroadcastType("cleric", "%player% attempts praying")
		wait 30 ticks
		send "&6The gods do not seem to answer..." to player
		play sound "entity.elder_guardian.ambient" with pitch 0.7 at player

command /channel <text>:
	executable by: players
	trigger:
		hasClass(player, "cleric") is true
		if arg 1 is "regen":
			subMana(player, 300) is false:
				send "&cYou do not have enough mana to bless nearby allies with regeneration!" to player
				stop
			loop players in radius 20 of player:
				applyEffect(loop-player, "regen", 1800 seconds)
				send "&6A Cleric blesses you with regeneration!" to loop-player
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You bless your allies with regeneration!" to player
		else if arg 1 is "haste":
			subMana(player, 300) is false:
				send "&cYou do not have enough mana to bless nearby allies with haste!" to player
				stop
			loop players in radius 20 of player:
				apply haste 3 to loop-player for 1800 seconds replacing the existing effect
				loop-player is not player
				send "&6A Cleric blesses you with haste!" to loop-player
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You bless your allies with haste!" to player
		else if arg 1 is "absorb":
			subMana(player, 300) is false:
				send "&cYou do not have enough mana to bless nearby allies with absorption!" to player
				stop
			loop players in radius 20 of player:
				apply absorption 5 to loop-player for 300 seconds replacing the existing effect
				loop-player is not player
				send "&6A Cleric blesses you with absorption!" to loop-player
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You bless your allies with absorption!" to player
		else if arg 1 is "cure":
			subMana(player, 300) is false:
				send "&cYou do not have enough mana to cure nearby allies!" to player
				stop
			loop all players in radius 20 of player:
				isMonster(loop-player) is false
				removeNegativeEffects(loop-player)
				cure loop-player
				loop-player is not player
				send "&6A Cleric cures you of your ailments!" to loop-player
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You cure your allies of their ailments!" to player
		else if arg 1 is "resource":
			subMana(player, 300) is false:
				send "&cYou do not have enough mana to resource boost nearby allies!" to player
				stop
			loop all players in radius 20 of player:
				applyEffect(loop-player, "resourceboost", 1800 seconds)
				loop-player is not player:
					send "&6A A Cleric boosts your resource capabilities!" to loop-player
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You boost your allies resource capabilities!" to player
		else if arg 1 is "cleanse":
			subMana(player, 1000) is false:
				send "&cYou do not have enough mana to cleanse the area!" to player
				stop
			loop all entities in radius 30 around player:
				if isMonster(loop-entity) is true:
					{-evilSkript::%loop-entity%::isBoss} is not true
					kill loop-entity
				else:
					removeNegativeEffects(loop-entity)
					cure loop-entity
					applyEffect(loop-entity, "spirit", 60 seconds)
					applyEffect(loop-entity, "regen", 1800 seconds)
					loop-entity is a player
					loop-entity is not player
					send "&6You feel a sense of purity wash over you!" to loop-entity
			play sound "item.trident.thunder" with pitch 2.0 at player
			send "&6You cleanse the area!" to player
					
		else:
			send "&cUnrecognized ability" to player
		scriptDebugBroadcastType("cleric", "%player% attempts channeling %arg 1%")

command /soulbond <player>:
	executable by: players
	trigger:
		hasEffect(player, "soulbond") is true:
			send "&cYou are already bonded!" to player
			stop				
		hasEffect(arg 1, "soulbond") is true:
			send "&c%arg 1% is soulbonded already!" to player
			stop						
		hasClass(player, "cleric") is true
		arg 1 is player:
			send "&cIt is greedy and selfish to tap into powers for yourself..." to player
			stop				
		subMana(player, 750) is false:
			send "&cYou do not have enough mana to create a soulbond!" to player
			stop			
		applyEffect(player, "soulbond", 10 minutes)
		set {-rpgSkript::%player%::soulbond} to true
		set {-rpgSkript::%player%::soulbondplayer} to arg 1
		applyEffect(arg 1, "soulbond", 10 minutes)
		set {rpgSkript::%arg 1%::soulbond} to true
		set {rpgSkript::%arg 1%::soulbondplayer} to player
		send "&3You create a soulbond with %arg 1%!" to player
		send "&3%player% creates a soulbond with you!" to arg 1
		play sound "item.trident.thunder" with pitch 2.0 at player
		scriptDebugBroadcastType("cleric", "%player% attempts soulbonding with %arg 1%")

command /soulbondtp:
	executable by: players
	trigger:
		{-rpgSkript::%player%::soulbond} is true
		teleport player to {-rpgSkript::%player%::soulbondplayer}


on right click with totem of undying:
	hasClass(event-player, "cleric") is true
	scriptDebugBroadcastType("cleric", "%player% attempts reviving")
	set {_dead} to false
	loop all players:
		loop-player is not event-player
		scriptDebugBroadcastType("cleric", "%player% detects %loop-entity% in revive")
		if loop-player is dead:
			scriptDebugBroadcastType("cleric", "%player% detects that %loop-entity% is dead")
			distance between loop-player and event-player is less than 11
			scriptDebugBroadcastType("cleric", "%player% detects that %loop-entity% is a player")
			set {_dead} to true
			scriptDebugBroadcastType("cleric", "%player% detects nearby dead player - %loop-entity% - Detected Death is %{_dead}%")
	if {_dead} is false:
		send "&cNo Nearby Dead Players!" to event-player
		stop
		scriptDebugBroadcastType("cleric", "%player% finds no nearby dead players")
	if subMana(event-player, 500) is false:
		send "&cNot enough mana to cast Revive!" to event-player
		stop		
	loop all players:
		if loop-player is dead:
			distance between loop-player and event-player is less than 11
			force loop-player to respawn
			teleport loop-player to event-player
			set health of loop-player to 3
			applyEffect(loop-player, "regen", 10 seconds)	
			apply saturation 1 without particles to loop-player for 10 seconds replacing the existing effect	
			applyEffect(loop-player, "spirit", 10 seconds)
			play sound "block.bell.use" with pitch 2.0 at loop-player
			send "&3%event-player% revives you!" to loop-player
			send "&3You revive %loop-entity%!" to event-player
			scriptDebugBroadcastType("cleric", "%player% respawns %loop-entity%")
	play sound "block.bell.use" with pitch 2.0 at event-player
	add 3 experience to event-player
	set {_dead} to false

on left click with totem of undying:
	if at least one of:
		hasClass(event-player, "cleric") is true
		hasClass(event-player, "paladin") is true
	then:
		scriptDebugBroadcastType("cleric", "%player% attempts casting Regeneration!")
		if subMana(event-player, {rpgSkript::maxMana::%event-player%} / 3 ) is false:
			send "&cNot enough mana to cast the Dampen spell!" to event-player
			stop
		createWorldEffect(location of event-player, "dampen", 60 seconds, event-player)
		send "&3You cast the Dampen Spell!" to event-player
		play sound "block.bell.use" with pitch 2.0 at event-player
		add 5 experience to event-player
				
# Barbarian

function rageTrigger(player: player):
	play sound "entity.player.attack.nodamage" at {_player}
	if hasEffect({_player}, "rage") is true:
		heal({_player}, 3)
		loop all entities in radius 5 around {_player}:
			chance of 50%:
				loop-entity is not {_player}
				isMonster(loop-entity) is true
				damage loop-entity by 1
				applyEffect(loop-entity, "bleeding", 2 seconds)
				apply slowness 1 to loop-entity for 5 seconds replacing the existing effect
				apply weakness 1 to loop-entity for 5 seconds replacing the existing effect
				set {_vec} to vector between {_player} and loop-entity
				set y component of {_vec} to 0
				set {_vec} to normalized {_vec}
				push loop-entity {_vec} with force 1.1
				push loop-entity upwards with force 0.6
	applyEffect({_player}, "rage", 30 seconds)

function setupEnergy(player: player):
	if {rpgSkript::%{_player}%::Energy} is not set:
		set {rpgSkript::%{_player}%::Energy} to 0
	if {rpgSkript::%{_player}%::maxEnergy} is not set:
		set {rpgSkript::%{_player}%::maxEnergy} to 0

	set {_newEnergy} to 0
	if hasClass({_player}, "monk") is true:
		set {_newEnergy} to 20
	else if hasClass({_player}, "rogue") is true:
		set {_newEnergy} to 15
	else if hasClass({_player}, "warrior") is true:
		set {_newEnergy} to 10
	else if hasClass({_player}, "barbarian") is true:
		set {_newEnergy} to 5

	if hasImbue({_player}, "Energy Boost") is true:
		set {_newEnergy} to {_newEnergy} + 0.25 * {_newEnergy} * countImbue({_player}, "Energy Boost")

	if hasEffect({_player}, "resourceboost") is true:
		set {_newEnergy} to {_newEnergy} + 5

	set {_newEnergy} to floor({_newEnergy})
	if {_newEnergy} is not {rpgSkript::%{_player}%::maxEnergy}:
		set {rpgSkript::%{_player}%::maxEnergy} to {_newEnergy}
		send "&4Your maximum Energy has changed to %{_newEnergy}%" to {_player}

function checkEnergy(player: player):
	setupEnergy({_player})
	if {rpgSkript::%{_player}%::Energy} > {rpgSkript::%{_player}%::maxEnergy}:
		set {rpgSkript::%{_player}%::Energy} to {rpgSkript::%{_player}%::maxEnergy}
	if {rpgSkript::%{_player}%::Energy} < 0:
		set {rpgSkript::%{_player}%::Energy} to 0

function regenEnergy(player: player):
	if {rpgSkript::%{_player}%::Energy} is not set:
		setupEnergy({_player})
	if {rpgSkript::%{_player}%::maxEnergy} is not set:
		setupEnergy({_player})

	set {_add} to 0
	if hasClass({_player}, "monk") is true:
		set {_add} to {rpgSkript::%{_player}%::maxEnergy} / 75
	else if hasClass({_player}, "rogue") is true:
		set {_add} to {rpgSkript::%{_player}%::maxEnergy} / 100
	else if hasClass({_player}, "warrior") is true:
		set {_add} to {rpgSkript::%{_player}%::maxEnergy} / 125
	else if hasClass({_player}, "barbarian") is true:
		set {_add} to {rpgSkript::%{_player}%::maxEnergy} / 150

	if hasEffect({_player}, "resourceboost") is true:
		set {_add} to {rpgSkript::%{_player}%::maxEnergy} / 100
		
	addEnergy( {_player}, {_add} )

function addEnergy(player: player, amount: number):
	set {_before} to {rpgSkript::%{_player}%::Energy}
	set {rpgSkript::%{_player}%::Energy} to {rpgSkript::%{_player}%::Energy} + {_amount}
	checkEnergy({_player})
	if abs( {rpgSkript::%{_player}%::Energy} - {_before} ) > 0.01:
		displayEnergy({_player})

function subEnergy(player: player, amount: number, print: boolean=true) :: boolean:
	{_player} has permission "rpg.control":
		return true
	if {rpgSkript::%{_player}%::Energy} is not set:
		return false
	if hasEnergy({_player}, {_amount}, {_print}) is true:
		set {rpgSkript::%{_player}%::Energy} to {rpgSkript::%{_player}%::Energy} - {_amount}
		checkEnergy({_player})
		displayEnergy({_player})
		return true
	else:
		return false

function hasEnergy(player: player, amount: number, print: boolean=true) :: boolean:
	{_player} has permission "rpg.control":
		return true
	if {_print} is true:
		send "&4Energy: Have %{rpgSkript::%{_player}%::Energy}%, Need %{_amount}%" to {_player}
	if {rpgSkript::%{_player}%::Energy} - {_amount} > -0.01:
		return true
	return false

function displayEnergy(player: player):
	set {_dispR} to {rpgSkript::%{_player}%::Energy}
	if {_dispR} < 0:
		set {_dispR} to 0
	send action bar "&4Energy: %{_dispR}% / %{rpgSkript::%{_player}%::maxEnergy}%" to {_player}

command /barbarianresearch:
	executable by: players
	trigger:
		hasClass(player, "barbarian") is false:
			send "&dYou are not a barbarian!"
			exit
		set {_menu} to a new chest inventory with 6 rows named "&cBarbarian Research"
		
		populateBarbarianResearchMenu(player, {_menu})
		
		open {_menu} to player

function populateBarbarianResearchMenu(player: player, menu: inventory):	
	set {_item} to red wool named "&7Leap"
	if hasResearch({_player}, "leap") is true:
		set {_item} to lime wool named "&eLeap"
	set line 1 of {_item}'s lore to "&6R-Clicking Glowstone Dust causes you to leap in the air, creating an earthquake on impact"
	set slot 31 of {_menu} to {_item}
	
	set {_item} to red wool named "&7Reckless Attack"
	if hasResearch({_player}, "reckless_attack") is true:
		set {_item} to lime wool named "&eReckless Attack"
	set line 1 of {_item}'s lore to "&6Rerolls low damage hits to either increase the damage or set it to 0"
	set slot 32 of {_menu} to {_item}

	set {_item} to red wool named "&7Throwables"
	if hasResearch({_player}, "throwables") is true:
		set {_item} to lime wool named "&ethrowables"
	set line 1 of {_item}'s lore to "&6Eggs and Snowballs can be used to deal damage when thrown."
	set slot 33 of {_menu} to {_item}

	set {_item} to red wool named "&7Thorns"
	if hasResearch({_player}, "Thorns") is true:
		set {_item} to lime wool named "&eThorns"
	set line 1 of {_item}'s lore to "&6Increased Inheritent Thorns Damage."
	set slot 34 of {_menu} to {_item}

on inventory click:
	event-inventory is not event-player's inventory
	name of event-inventory is "&cBarbarian Research"
	cancel event

	if index of event-slot is 34:
		if hasResearch(player, "Thorns") is true:
			deleteResearch(player, "Thorns")
		else:
			takeItems( player, (24 iron ingot) ) is false:
				send "&4~ ~ Need 24 iron ingot for this Research ~ ~" to player
				stop
			addResearch(player, "thorns")

	if index of event-slot is 31:
		if hasResearch(player, "leap") is true:
			deleteResearch(player, "leap")
		else:
			takeItems( player, (1 potion of leaping and 16 ghast tear ) ) is false:
				send "&4~ ~ Need 1 Potion of Leaping & 16 Ghast Tears for this Research ~ ~" to player
				stop
			addResearch(player, "leap")

	if index of event-slot is 32:
		if hasResearch(player, "reckless_attack") is true:
			deleteResearch(player, "reckless_attack")
		else:
			takeItems( player, (32 red dye and 64 redstone dust ) ) is false:
				send "&4~ ~ Need 32 Red Dye & 64 Redstone Dust for this Research ~ ~" to player
				stop
			addResearch(player, "reckless_attack")

	if index of event-slot is 33:
		if hasResearch(player, "throwables") is true:
			deleteResearch(player, "throwables")
		else:
			takeItems( player, (16 egg, 16 snowball, and 32 red dye ) ) is false:
				send "&4~ ~ Need 16 Eggs, 16 Snowballs, and 32 Red Dye for this Research ~ ~" to player
				stop
			addResearch(player, "throwables")
	
	populateBarbarianResearchMenu(player, event-inventory)

function canUseBarbarianAbilities(player: player) :: boolean:
	if {_player} has potion effect weakness:
		return false
	else if {_player}'s off hand item is a shield:
		return false
	else if isWearingMediumOrLess({_player}) is true:
		return true
	return false	

on right click with red dye:
	hasClass(event-player, "barbarian") is true
	canUseBarbarianAbilities(event-player) is true
	subEnergy(event-player, 1) is true:
		rageTrigger(event-player)

on right click with glowstone dust:
	player is sprinting
	player is on the ground
	if hasClass(player, "barbarian") is true:
		if canUseBarbarianAbilities(player) is true:
			if hasResearch(player, "leap") is true:
				subEnergy(player, 1) is true:
					push player horizontally forward with force 1.9
					push player upwards with force 0.95
					send "&cYou leap!" to player
					wait 5 ticks
					while player is not on ground:
						wait 1 tick
					send "&cYou crush nearby enemies!" to player
					loop all entities in radius 6 around player:
						loop-entity is not player
						damage loop-entity by 3.5
						apply slowness 1 to loop-entity for 5 seconds replacing the existing effect
						set {_vec} to vector between player and loop-entity
						set y component of {_vec} to 0
						set {_vec} to normalized {_vec}
						push loop-entity {_vec} with force 1.6
						push loop-entity upwards with force 0.9

on right click with rabbit's foot:
	player is on the ground
	if hasClass(player, "barbarian") is true:
		subEnergy(player, 1) is true:
			send "&cYou dash!" to player
			if hasClass(player, "barbarian") is true:
				push player horizontally forward with force 5.0
				wait 5 ticks
				loop all entities in radius 3 around player:
					loop-entity is not player
					damage loop-entity by 6
					apply slowness 1 to loop-entity for 5 seconds replacing the existing effect
					set {_vec} to vector between player and loop-entity
					set y component of {_vec} to 0
					set {_vec} to normalized {_vec}
					push loop-entity {_vec} with force 1.6
					loop all blocks in radius 2.99 around player:
						if at least one of:
							loop-block is gravel
							loop-block is dirt
							loop-block is grass block
							loop-block is sand
							loop-block is any leaves
						then:
							y coordinate of loop-block - y coordinate of player is less than 3:
								y coordinate of loop-block - y coordinate of player is greater than 0:							
									break loop-block naturally

on left click with chains:
	hasClass(event-player, "barbarian") is true
	canUseBarbarianAbilities(event-player) is true
	if subEnergy(event-player, 1) is false:
		send "&4You do do not have the Energy to cast the Chains spell." to event-player
		stop
	else:
		send "&cYou cast the Chains spell." to event-player
		set {_Block} to 0
		set {_Cone} to 0
		loop 8 times:
			add 1 to {_Block}
			add 2 to {_Cone}
			set {_GetBlock} to block {_Block} blocks infront of event-player
			loop all entities in radius {_Cone} around {_GetBlock}:
				loop-entity is not event-player
				apply slowness 255 to loop-entity for 3 seconds replacing the existing effect				
				apply weakness 2 to loop-entity for 5 seconds replacing the existing effect
				teleport loop-entity to location of the block above the block 2 blocks in front of event-player

on right click with (any sword or any axe):
	hasClass(event-player, "barbarian") is true
	canUseBarbarianAbilities(event-player) is true
	if at least one of:
		event-player's targeted block is any log
		event-player's targeted block is any door
	then:
		stop
	if subEnergy(event-player, 1) is false:
		send "&4You do do not have the Energy to Cleave!" to event-player
		stop
	else:
		send "&cYou Cleave!" to event-player
		set {_Block} to 0
		set {_Cone} to 0
		loop 2 times:
			add 1 to {_Block}
			add 2 to {_Cone}
			set {_GetBlock} to block {_Block} blocks infront of event-player
			loop all entities in radius {_Cone} around {_GetBlock}:
				loop-entity is not event-player	
				set {_randmg} to a random number between 4 and 10
				if hasEffect(event-player, "rage") is true:
					damage loop-entity by {_randmg}
				else:
					damage loop-entity by {_randmdg}/2
		
						



# Endwarden



function canUseEndwardenAbilities(player: player) :: boolean:
	if isWearingLightOrLess({_player}) is true:
		return true
	return false
on right click with end crystal:
	hasClass(event-player, "endwarden") is true
	canUseEndwardenAbilities(event-player) is true
	if subMana(event-player, 500) is false:
		send "&4You do not have the required mana to cast the Black Hole Spell!" to event-player
		stop
	createWorldEffect(event-player's targeted block, "black hole", 20 seconds, event-player)
	play sound "block.end_portal.spawn" at player



on right click with (ender pearl or eye of ender):
	hasClass(event-entity, "endwarden") is true:
		event-entity's off hand item is an ender pearl:
			cancel the event
		event-entity's held item is an ender pearl:
			cancel the event
		event-entity's held item is not air:
			event-entity's off hand item is an ender pearl:
				cancel the event
		event-entity's off hand item is an eye of ender:
			cancel the event

on right click with phantom membrane:
	hasClass(event-player, "endwarden") is true
	canUseEndwardenAbilities(event-player) is true
	if subMana(event-player, 100) is false:
		send "&4You do not have the required mana to cast the Levitate spell!" to event-player
		stop
	createWorldEffect(event-player's targeted block, "levitate", 20 seconds, event-player)

on left click with phantom membrane:
	hasClass(event-player, "endwarden") is true
	canUseEndwardenAbilities(event-player) is true
	if subMana(event-player, 50) is false:
		send "&4You do not have the required mana to alter your density!" to event-player
		stop
	if {-rpgSkript::%event-player%::float} is true:
		set {-rpgSkript::%event-player%::float} to false
		send "You increase your own gravity." to event-player
	else:
		set {-rpgSkript::%event-player%::float} to true
		send "You disable your own gravity." to event-player
	
