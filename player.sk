    set line 1 of {_item}'s lore to "&bAllows you to Construct AoF Tesla Constructs"
    set slot 1 of {_menu} to {_item}
  
    set {_item} to red wool named "&4Guardian Construct"
    if hasResearch({_player}, "guardian_construct") is true:
